#!/bin/bash
# shuttle - CLI for managing Claude Code agent sessions
# Usage: shuttle [command] [args]

set -e

# Parse --dir, --project, and --headless options
# Sets: PROJECT_DIR, HEADLESS, remaining args in POSITIONAL array
parse_project_opts() {
    PROJECT_DIR=""
    PROJECT_NAME=""
    HEADLESS=""
    POSITIONAL=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--dir)
                PROJECT_DIR="$2"
                shift 2
                ;;
            -p|--project)
                PROJECT_NAME="$2"
                shift 2
                ;;
            --headless)
                HEADLESS=1
                shift
                ;;
            *)
                POSITIONAL+=("$1")
                shift
                ;;
        esac
    done

    # Error if both set
    if [ -n "$PROJECT_DIR" ] && [ -n "$PROJECT_NAME" ]; then
        echo "Error: cannot use both --dir and --project"
        exit 1
    fi

    # Resolve project name to path
    if [ -n "$PROJECT_NAME" ]; then
        PROJECT_DIR="$HOME/projects/$PROJECT_NAME"
        if [ ! -d "$PROJECT_DIR" ]; then
            echo "Error: project not found: $PROJECT_DIR"
            exit 1
        fi
    fi

    # Default to current directory
    if [ -z "$PROJECT_DIR" ]; then
        PROJECT_DIR="$(pwd)"
    fi

    # Headless: explicit flag, env var, or no display
    if [ -n "$SHUTTLE_HEADLESS" ] || [ -z "$DISPLAY" ]; then
        HEADLESS=1
    fi
}

# Send a message to a tmux pane and press Enter
# Usage: tmux_send_cmd <target> <message>
# NOTE: Must use two separate send-keys calls when using -t target!
# Single-line "message" Enter doesn't work reliably with -t flag.
tmux_send_cmd() {
    local target="$1"
    local message="$2"
    tmux send-keys -t "$target" "$message"
    sleep 0.1
    tmux send-keys -t "$target" Enter
}

CMD="${1:-status}"
shift 2>/dev/null || true

case "$CMD" in
    status)
        # Start slow skein calls in parallel
        BRIEFS_TMP=$(mktemp)
        SHARDS_TMP=$(mktemp)
        trap "rm -f $BRIEFS_TMP $SHARDS_TMP" EXIT

        (skein folios ledger --type brief --status open 2>/dev/null | grep "brief-" | head -5 > "$BRIEFS_TMP") &
        BRIEFS_PID=$!
        (skein shard triage 2>/dev/null | tail -n +3 > "$SHARDS_TMP") &
        SHARDS_PID=$!

        # Sessions (fast, do synchronously)
        echo "SESSIONS:"
        SESSIONS=$(tmux ls 2>/dev/null || true)
        if [ -z "$SESSIONS" ]; then
            echo "  (none)"
        else
            i=1
            while IFS= read -r line; do
                NAME=$(echo "$line" | cut -d: -f1)
                ATTACHED=$(echo "$line" | grep -q "attached" && echo "attached" || echo "detached")
                CREATED=$(echo "$line" | grep -oP 'created [^)]+' | sed 's/created //')
                echo "  [$i] $NAME  ($ATTACHED)  $CREATED"
                ((i++))
            done <<< "$SESSIONS"
        fi
        echo ""

        # Wait for briefs and display
        wait $BRIEFS_PID 2>/dev/null
        echo "READY BRIEFS:"
        if [ -s "$BRIEFS_TMP" ]; then
            while read -r line; do
                echo "  $line"
            done < "$BRIEFS_TMP"
        else
            echo "  (none)"
        fi
        echo ""

        # Wait for shards and display
        wait $SHARDS_PID 2>/dev/null
        echo "SHARDS:"
        TRIAGE=$(cat "$SHARDS_TMP")
        if [ -z "$TRIAGE" ]; then
            echo "  (unavailable)"
        else
            READY=$(echo "$TRIAGE" | grep -c "✓" 2>/dev/null || true)
            CONFLICT=$(echo "$TRIAGE" | grep -c "⚠" 2>/dev/null || true)
            EMPTY=$(echo "$TRIAGE" | grep -c "empty" 2>/dev/null || true)
            echo "  ${READY:-0} ready, ${CONFLICT:-0} conflicts, ${EMPTY:-0} empty"
        fi
        ;;

    ls|list)
        tmux ls 2>/dev/null | nl -w2 -s'] ' | sed 's/^/[/' || echo "(no sessions)"
        ;;

    briefs)
        SITE="${1:-ledger}"
        echo "Open briefs in $SITE:"
        skein folios "$SITE" --type brief --status open 2>/dev/null | grep -E "brief-|^$" || echo "(none)"
        ;;

    board|b)
        # Check for --headless flag
        HEADLESS=""
        TARGET=""
        for arg in "$@"; do
            if [ "$arg" = "--headless" ]; then
                HEADLESS=1
            else
                TARGET="$arg"
            fi
        done
        # Also check env var and display
        if [ -n "$SHUTTLE_HEADLESS" ] || [ -z "$DISPLAY" ]; then
            HEADLESS=1
        fi

        if [ -z "$TARGET" ]; then
            echo "Usage: shuttle board [--headless] <number|name>"
            exit 1
        fi

        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$TARGET" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $TARGET"
            exit 1
        fi

        echo "Boarding $SESSION..."
        if [ -n "$HEADLESS" ]; then
            tmux attach -t "$SESSION"
        else
            dbus-launch gnome-terminal -- tmux attach -t "$SESSION" 2>/dev/null
        fi
        ;;

    kill|k)
        if [ -z "$1" ]; then
            echo "Usage: shuttle kill <number|name>"
            exit 1
        fi

        if [[ "$1" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${1}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$1" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $1"
            exit 1
        fi

        echo "Killing $SESSION..."
        tmux kill-session -t "$SESSION"
        echo "Done."
        ;;

    send)
        if [ -z "$1" ] || [ -z "$2" ]; then
            echo "Usage: shuttle send <number|name> <message>"
            exit 1
        fi

        TARGET="$1"
        MESSAGE="$2"

        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$TARGET" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $TARGET"
            exit 1
        fi

        echo "Sending to $SESSION: $MESSAGE"
        tmux_send_cmd "$SESSION" "$MESSAGE"
        ;;

    peek|p)
        TARGET="${1:-1}"
        LINES="${2:-20}"

        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$TARGET" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $TARGET"
            exit 1
        fi

        echo "=== $SESSION (last $LINES lines) ==="
        tmux capture-pane -t "$SESSION" -p | tail -n "$LINES"
        ;;

    go|g)
        parse_project_opts "$@"
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ]; then
            echo "Usage: shuttle go [--dir PATH | --project NAME] <brief-id>"
            exit 1
        fi
        BRIEF_ID="$1"

        # Get brief title for human-readable session name
        BRIEF_TITLE=$(skein folio "$BRIEF_ID" 2>/dev/null | grep "^    #" | head -1 | sed 's/^[[:space:]]*#[[:space:]]*//' | tr ' ' '-' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g' | sed 's/--*/-/g' | cut -c1-25)

        if [ -z "$BRIEF_TITLE" ]; then
            SESSION="shuttle-${BRIEF_ID}"
        else
            SESSION="shuttle-${BRIEF_TITLE}"
        fi

        # Check if session already exists - reboard instead of creating new
        if tmux has-session -t "$SESSION" 2>/dev/null; then
            echo "Session '$SESSION' exists - reboarding..."
            if [ -n "$HEADLESS" ]; then
                echo "Attach with: tmux attach -t $SESSION"
            else
                dbus-launch gnome-terminal -- tmux attach -t "$SESSION" 2>/dev/null
            fi
            exit 0
        fi

        echo "Launching: $SESSION (in $PROJECT_DIR)"

        # Create new tmux session running claude
        tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR" "claude"

        # Wait for claude prompt to appear
        echo "Waiting for Claude..."
        for i in {1..60}; do
            CAPTURED=$(tmux capture-pane -t "$SESSION" -p)
            # Look for Claude's prompt or shortcuts hint
            if echo "$CAPTURED" | grep -qE "^>|? for"; then
                echo "Ready!"
                break
            fi
            sleep 0.2
        done

        # Send the HANDOFF message
        tmux_send_cmd "$SESSION" "HANDOFF: $BRIEF_ID"

        # Open terminal or print attach instructions
        if [ -n "$HEADLESS" ]; then
            echo "Session ready: $SESSION"
            echo "Attach with: tmux attach -t $SESSION"
        else
            dbus-launch gnome-terminal -- tmux attach -t "$SESSION" 2>/dev/null
            echo "Launched $SESSION"
        fi
        ;;

    split|s|vsplit|vs)
        # Determine split direction
        if [[ "$CMD" == "vsplit" || "$CMD" == "vs" ]]; then
            SPLIT_FLAG="-v"
            SPLIT_TYPE="vertical"
        else
            SPLIT_FLAG="-h"
            SPLIT_TYPE="horizontal"
        fi

        parse_project_opts "$@"
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ]; then
            echo "Usage: shuttle $CMD [--dir PATH | --project NAME] <brief-id>"
            exit 1
        fi

        if [ -z "$TMUX" ]; then
            echo "Error: $CMD requires being inside a tmux session"
            echo "Use 'shuttle go <brief>' to launch in a new window instead"
            exit 1
        fi

        BRIEF_ID="$1"
        echo "Opening $SPLIT_TYPE split for $BRIEF_ID (in $PROJECT_DIR)..."

        # Create split running claude, capture the new pane ID
        NEW_PANE=$(tmux split-window $SPLIT_FLAG -c "$PROJECT_DIR" -P -F '#{pane_id}' "claude")

        # Wait for claude prompt in the NEW pane
        echo "Waiting for Claude..."
        for i in {1..60}; do
            CAPTURED=$(tmux capture-pane -t "$NEW_PANE" -p)
            # Look for Claude's prompt or shortcuts hint
            if echo "$CAPTURED" | grep -qE "^>|? for"; then
                break
            fi
            sleep 0.2
        done

        # Send the HANDOFF to the specific pane we created
        tmux_send_cmd "$NEW_PANE" "HANDOFF: $BRIEF_ID"
        echo "Split opened. Use 'shuttle unsplit' to close."
        ;;

    unsplit)
        if [ -z "$TMUX" ]; then
            echo "Error: unsplit requires being inside a tmux session"
            exit 1
        fi

        PANE_COUNT=$(tmux list-panes | wc -l)
        if [ "$PANE_COUNT" -eq 1 ]; then
            echo "No split pane to close"
            exit 0
        fi

        # Kill the other pane (not the current one)
        CURRENT_PANE=$(tmux display-message -p '#{pane_index}')
        if [ "$CURRENT_PANE" -eq 0 ]; then
            tmux kill-pane -t 1
        else
            tmux kill-pane -t 0
        fi
        echo "Split closed."
        ;;

    watch|w)
        while true; do
            clear
            "$0" status
            sleep 2
        done
        ;;

    ground)
        tmux ls 2>/dev/null | grep "^shuttle-" | cut -d: -f1 | while read -r sess; do
            echo "  Killing $sess"
            tmux kill-session -t "$sess"
        done
        echo "Done."
        ;;

    help|--help|-h)
        cat << 'EOF'
shuttle - Manage Claude Code agent sessions

Commands:
  status          Show sessions, briefs, and shards (default)
  watch, w        Continuous status refresh (Ctrl-C to exit)
  ls              List active sessions
  board, b <n>    Board session by number or name
  kill, k <n>     Kill session by number or name
  peek, p <n> [lines]  Show last lines from session (default: 20)
  send <n> <msg>  Send message to session
  go, g <brief>   Launch new session on a brief
  split, s <brief>   Open brief in horizontal split pane
  vsplit, vs <brief> Open brief in vertical split pane
  unsplit         Close split pane
  ground          Kill all shuttle sessions

Options (for go, board, split, vsplit):
  -d, --dir PATH      Run in specified directory (go, split, vsplit)
  -p, --project NAME  Run in ~/projects/NAME (go, split, vsplit)
  --headless          Don't open GUI terminal (go, board)
  (default: current directory, auto-headless if no $DISPLAY)

Environment:
  SHUTTLE_HEADLESS=1  Force headless mode

Examples:
  shuttle                     # show status
  shuttle go brief-20251210-ceor
  shuttle go -p skein brief-20251210-ceor  # launch in skein project
  shuttle go --headless brief-id  # create session without opening terminal
  shuttle split brief-20251210-ceor  # side-by-side pairing
  shuttle board 1             # board first session
  shuttle peek 1              # see what session 1 is doing
  shuttle peek 2 50           # last 50 lines from session 2
  shuttle send 1 "check the failing tests"  # nudge a session
  shuttle send 2 "skein torch"  # trigger retirement
  shuttle kill diverge        # kill session matching 'diverge'
EOF
        ;;

    *)
        echo "Unknown command: $CMD"
        echo "Run 'shuttle help' for usage"
        exit 1
        ;;
esac

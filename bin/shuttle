#!/bin/bash
# shuttle - CLI for managing Claude and Codex agent sessions
# Usage: shuttle [command] [args]

set -e

# Resolve the directory containing this script (for finding sibling modules)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
SHUTTLE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Field separator for parsing `tmux -F` output: a literal 0x1f (ASCII unit separator).
# tmux permits '|', spaces and most punctuation inside session names, so any printable
# delimiter can also occur in the data and split a name in half.
SEP=$'\x1f'

# =============================================================================
# Configuration
# =============================================================================

# Default configuration values
ENV_SHUTTLE_DEFAULT_AGENT="${SHUTTLE_DEFAULT_AGENT:-}"
SHUTTLE_DEFAULT_PROJECT=""           # Default project directory (empty = use pwd)
SHUTTLE_DEFAULT_SITE="ledger"        # Default site for briefs
SHUTTLE_DEFAULT_AGENT="claude"       # Default interactive provider
SHUTTLE_HEADLESS_DEFAULT=""          # Default headless mode (empty = auto-detect)
SHUTTLE_PROMPT_TIMEOUT=12            # Seconds to wait for Claude prompt

# Config file locations (checked in order)
SHUTTLE_CONFIG_PATHS=(
    "${XDG_CONFIG_HOME:-$HOME/.config}/shuttle/config"
    "$HOME/.shuttlerc"
)

# Load configuration from file if it exists
load_config() {
    for config_path in "${SHUTTLE_CONFIG_PATHS[@]}"; do
        if [ -f "$config_path" ]; then
            # Source bash-style KEY=value config
            # shellcheck disable=SC1090
            source "$config_path"
            SHUTTLE_LOADED_CONFIG="$config_path"
            return 0
        fi
    done
    SHUTTLE_LOADED_CONFIG=""
    return 0
}

# Get effective config value (precedence: env var > config file > default)
# After load_config, variables are already set via sourcing
# Env vars with same name will override (since they're not overwritten by source)

# Load config at startup (before any command processing)
load_config

[ -n "$ENV_SHUTTLE_DEFAULT_AGENT" ] && SHUTTLE_DEFAULT_AGENT="$ENV_SHUTTLE_DEFAULT_AGENT"

# Apply environment variable overrides (higher precedence than config file)
[ -n "$SHUTTLE_PROJECT" ] && SHUTTLE_DEFAULT_PROJECT="$SHUTTLE_PROJECT"
[ -n "$SHUTTLE_SITE" ] && SHUTTLE_DEFAULT_SITE="$SHUTTLE_SITE"
[ -n "$SHUTTLE_TIMEOUT" ] && SHUTTLE_PROMPT_TIMEOUT="$SHUTTLE_TIMEOUT"

# =============================================================================
# Helper Functions
# =============================================================================

# Parse --dir, --project, --agent, and --headless options
# Sets: PROJECT_DIR, HEADLESS, AGENT, remaining args in POSITIONAL array
parse_project_opts() {
    PROJECT_DIR=""
    PROJECT_NAME=""
    EXPLICIT_DIR=""
    HEADLESS=""
    AGENT="$SHUTTLE_DEFAULT_AGENT"
    POSITIONAL=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--dir)
                PROJECT_DIR="$2"
                EXPLICIT_DIR=1
                shift 2
                ;;
            -p|--project)
                PROJECT_NAME="$2"
                shift 2
                ;;
            --headless)
                HEADLESS=1
                shift
                ;;
            --agent)
                AGENT="$2"
                shift 2
                ;;
            *)
                POSITIONAL+=("$1")
                shift
                ;;
        esac
    done

    validate_agent "$AGENT"

    # Error if both set
    if [ -n "$PROJECT_DIR" ] && [ -n "$PROJECT_NAME" ]; then
        echo "Error: cannot use both --dir and --project"
        exit 1
    fi

    # Resolve project name to path
    if [ -n "$PROJECT_NAME" ]; then
        PROJECT_DIR="$HOME/projects/$PROJECT_NAME"
        if [ ! -d "$PROJECT_DIR" ]; then
            echo "Error: project not found: $PROJECT_DIR"
            exit 1
        fi
    fi

    # Default: config default project, or current directory
    if [ -z "$PROJECT_DIR" ]; then
        if [ -n "$SHUTTLE_DEFAULT_PROJECT" ]; then
            PROJECT_DIR="${SHUTTLE_DEFAULT_PROJECT/#\~/$HOME}"
            if [ ! -d "$PROJECT_DIR" ]; then
                echo "Warning: default_project not found: $PROJECT_DIR (using pwd)"
                PROJECT_DIR="$(pwd)"
            fi
        else
            PROJECT_DIR="$(pwd)"
        fi
    fi

    # Headless: explicit flag, env var, config default, or no display
    if [ -n "$SHUTTLE_HEADLESS" ] || [ -n "$SHUTTLE_HEADLESS_DEFAULT" ] || [ -z "$DISPLAY" ]; then
        HEADLESS=1
    fi
}

validate_agent() {
    case "$1" in
        claude|codex) ;;
        *)
            echo "Error: --agent must be claude or codex"
            exit 1
            ;;
    esac
}

claude_only_args() {
    local command="$1"
    shift
    CLAUDE_ARGS=()
    while [[ $# -gt 0 ]]; do
        if [ "$1" = "--agent" ]; then
            validate_agent "$2"
            if [ "$2" != "claude" ]; then
                echo "Error: shuttle $command is Claude-only in this release"
                exit 1
            fi
            shift 2
        else
            CLAUDE_ARGS+=("$1")
            shift
        fi
    done
}

# Slugify the first heading of a `skein folio` dump into a session-name fragment.
#
# Strips every leading '#', not just one: a body whose first heading is '## Foo'
# used to keep a '#', which the character scrub turned into a leading dash. That
# produced names like 'shuttle--foo' and, once the title reached the registry as
# '--title -foo', argparse read the value as a flag and the launch died.
# Reduce anything destined to BECOME a tmux session name to a conservative charset.
#
# tmux legally accepts newlines, '|', the 0x1f separator, and trailing spaces inside a
# session name — all of which break line- and field-oriented parsers downstream (a
# newline in a name makes `shuttle status` invent a phantom session; a trailing space
# makes `ground` skip the session it meant to kill). The cheap, total defence is to
# never create such a name: `shuttle go` otherwise builds one straight from an
# unvalidated brief id. This does not police names other tools created — the lookups
# fail closed on those — it just stops us manufacturing the problem ourselves.
safe_session_name() {
    local slug
    slug=$(printf '%s' "$1" \
        | tr -c 'A-Za-z0-9_-' '-' \
        | sed 's/--*/-/g; s/^-*//; s/-*$//' \
        | cut -c1-60)
    # Never return empty. An all-punctuation input ('!!!', '@@@') scrubs to nothing,
    # and two such inputs would collapse to the same 'shuttle-' name — so `go` would
    # reboard the FIRST brief's session instead of launching the second. Fall back to
    # a deterministic checksum of the raw input: non-empty, and distinct inputs stay
    # distinct. (cksum is byte-stable and needs no date/random, so it is resume-safe.)
    if [ -z "$slug" ]; then
        slug="x$(printf '%s' "$1" | cksum | cut -d' ' -f1)"
    fi
    printf '%s' "$slug"
}

brief_title_slug() {
    echo "$1" \
        | grep "^    #" \
        | head -1 \
        | sed 's/^[[:space:]]*#\{1,\}[[:space:]]*//' \
        | tr ' ' '-' \
        | tr '[:upper:]' '[:lower:]' \
        | sed 's/[^a-z0-9-]//g' \
        | sed 's/--*/-/g' \
        | cut -c1-25 \
        | sed 's/^-*//; s/-*$//'
}

# Parses one `skein folio <id>` render into the BRIEF_FOUND/BRIEF_OWNER
# globals. A bare (non `--all`) `skein folio` lookup resolves GLOBALLY once it
# has a scope to start from: it cascades to whichever registered project
# actually owns the brief. When the owner differs from the scope just
# queried, the render line carries an "[owner]" tag ("folio $BRIEF_ID
# [owner]"); when the owner IS the scope just queried, the tag is omitted
# ("folio $BRIEF_ID"). That tag is a real ~/.skein/projects.json key. `--all`'s
# tag is NOT: `--all` lists every project holding a synced copy (all of them,
# for a mesh-shared brief) and its embedded `site_id` is a SITE/workspace
# name, a different namespace than a projects.json key — see
# friction-20260715-0yd7 for the corrected finding.
parse_brief_render() {
    local brief_id="$1" render="$2" render_line
    render_line=$(echo "$render" | grep "^folio $brief_id" | head -1)
    if [ -n "$render_line" ]; then
        BRIEF_FOUND=1
        case "$render_line" in
            "folio $brief_id ["*"]")
                BRIEF_OWNER="${render_line#folio $brief_id [}"
                BRIEF_OWNER="${BRIEF_OWNER%]}"
                ;;
        esac
    fi
}

# Any registered project works as a probe scope for parse_brief_render's
# cascade — it does not care which project initiates the lookup, only that
# the lookup has SOME resolvable scope to start from (see
# resolve_brief_owner). "shuttle" is used because this IS the shuttle
# project, so it is reliably registered whenever `shuttle go`/`split` run
# from a normal install; fall back to whatever project happens to be
# registered first if it somehow isn't.
resolve_probe_scope() {
    [ -f ~/.skein/projects.json ] || return 1
    if jq -e '.projects["shuttle"]' ~/.skein/projects.json >/dev/null 2>&1; then
        echo "shuttle"
        return 0
    fi
    local first
    first=$(jq -r '.projects | keys[0] // empty' ~/.skein/projects.json 2>/dev/null) || true
    [ -n "$first" ] || return 1
    echo "$first"
}

# Resolves where BRIEF_ID actually lives and, if it belongs to a project
# other than PROJECT_DIR, moves PROJECT_DIR to the owner's registered path.
# Sets BRIEF_FOUND, BRIEF_OWNER and BRIEF_RENDER (the render text, for title
# extraction and not-found error reporting). Respects an explicit -d/-p: an
# explicit pin is never overridden.
#
# `skein folio` resolves its OWN scope from the invoking cwd (a `.skein` dir
# walked up from pwd, or SKEIN_PROJECT) before parse_brief_render's cascade
# ever runs. When neither exists — /tmp, $HOME, a bare ~/projects with no
# .skein — skein errors "No project specified" with EMPTY stdout, and the
# cascade never gets a chance to look anywhere. That is not "brief not
# found"; it is "never actually searched". So: try the scope the caller is
# actually running under first (PROJECT_NAME if given, else ambient cwd). If
# that comes back empty AND neither -d nor -p pinned a scope, retry once
# under an EXPLICIT, guaranteed-registered scope (independent of cwd) so
# resolution stops depending on where the command happened to be run from.
resolve_brief_owner() {
    local brief_id="$1"
    BRIEF_FOUND=""
    BRIEF_OWNER=""
    BRIEF_RENDER=""

    # `VAR=$(cmd)` takes cmd's exit status as its own: a bare failing
    # assignment kills the whole script under `set -e`, with no message.
    # `|| true` on the whole statement neutralizes that while still capturing
    # whatever skein printed — its own error text on failure, since skein
    # writes nothing to stdout when it errors (2>&1 folds that text into
    # BRIEF_RENDER).
    if [ -n "$PROJECT_NAME" ]; then
        BRIEF_RENDER=$(SKEIN_PROJECT="$PROJECT_NAME" skein folio "$brief_id" 2>&1) || true
    else
        BRIEF_RENDER=$(skein folio "$brief_id" 2>&1) || true
    fi
    parse_brief_render "$brief_id" "$BRIEF_RENDER"

    if [ -z "$BRIEF_FOUND" ] && [ -z "$EXPLICIT_DIR" ] && [ -z "$PROJECT_NAME" ]; then
        local probe_scope
        probe_scope=$(resolve_probe_scope) || probe_scope=""
        if [ -n "$probe_scope" ]; then
            local probe_render
            probe_render=$(SKEIN_PROJECT="$probe_scope" skein folio "$brief_id" 2>&1) || true
            parse_brief_render "$brief_id" "$probe_render"
            if [ -n "$BRIEF_FOUND" ]; then
                BRIEF_RENDER="$probe_render"
                # No "[owner]" tag means the probe scope itself is the
                # owner — same rule as any other scope, just a fixed one.
                [ -z "$BRIEF_OWNER" ] && BRIEF_OWNER="$probe_scope"
            fi
        fi
    fi

    # Move PROJECT_DIR to the owner whenever the brief cascaded in from a
    # different project than the one just queried. This must run whenever an
    # owner is known, NOT only when BRIEF_FOUND was empty going in: the
    # lookup above succeeds globally once scoped, so BRIEF_FOUND is set even
    # when PROJECT_DIR (still pwd) is the wrong directory.
    if [ -n "$BRIEF_OWNER" ] && [ -z "$EXPLICIT_DIR" ] && [ -z "$PROJECT_NAME" ]; then
        local owner_dir=""
        if [ -f ~/.skein/projects.json ]; then
            owner_dir=$(jq -r ".projects[\"$BRIEF_OWNER\"].path // empty" ~/.skein/projects.json 2>/dev/null) || true
        fi
        if [ -n "$owner_dir" ] && [ -d "$owner_dir" ]; then
            # Re-fetch scoped to the confirmed owner so the render (and any
            # title extracted from it) reflects it.
            BRIEF_RENDER=$(SKEIN_PROJECT="$BRIEF_OWNER" skein folio "$brief_id" 2>/dev/null) || true
            echo "Brief found in: $BRIEF_OWNER ($owner_dir)"
            PROJECT_DIR="$owner_dir"
        else
            # Owner known but its registered path is missing or stale. `-p
            # $BRIEF_OWNER` assumes a `~/projects/<name>` layout, which is
            # not necessarily where the owner is actually registered — do
            # not suggest a command that may itself be broken.
            echo "Brief belongs to project '$BRIEF_OWNER' but its registered path could not be resolved."
            echo "Check ~/.skein/projects.json, or pass -d <path> to launch there directly."
            exit 1
        fi
    fi
}

registry_cli() {
    PYTHONPATH="$SHUTTLE_ROOT${PYTHONPATH:+:$PYTHONPATH}" python3 -m shuttlelib.cli "$@"
}

close_launch_failed() {
    local launch_id="$1"
    local exit_code="$2"
    local message="$3"
    registry_cli degrade "$launch_id" "$message" || true
    registry_cli close "$launch_id" --status failed --exit-code "$exit_code" || true
}

run_tmux_new_session() {
    local session="$1"
    local project_dir="$2"
    local command="$3"
    local had_errexit=""

    case "$-" in
        *e*)
            had_errexit=1
            set +e
            ;;
    esac

    tmux new-session -d -s "$session" -c "$project_dir" "$command"
    TMUX_NEW_SESSION_RC=$?

    if [ -n "$had_errexit" ]; then
        set -e
    fi
    return 0
}

record_for_session() {
    registry_cli lookup-tmux --live "$1" 2>/dev/null
}

provider_for_session() {
    local record
    record=$(record_for_session "$1" || true)
    if [ -n "$record" ]; then
        echo "$record" | cut -d $'\x1f' -f2
    elif [[ "$1" == shuttle-codex-* ]]; then
        echo "codex"
    else
        echo "claude"
    fi
}

load_codex_send_record() {
    local session="$1"
    local record
    local -a fields
    CODEX_STATE="unknown"
    CODEX_PANE_ID=""
    CODEX_PID=""

    record=$(record_for_session "$session" || true)
    if [ -z "$record" ]; then
        return 0
    fi

    IFS=$'\x1f' read -r -a fields <<< "$record"
    CODEX_STATE="${fields[2]}"
    CODEX_PANE_ID="${fields[4]}"
    CODEX_PID="${fields[5]:-}"
    if [ "$CODEX_STATE" = "idle" ]; then
        if [ -z "$CODEX_PID" ]; then
            CODEX_STATE="stale"
        elif ! kill -0 "$CODEX_PID" 2>/dev/null; then
            CODEX_STATE="dead"
        fi
    fi
}

verify_codex_send_pane() {
    local expected_session="$1"
    local pane_id="$2"
    local pane_session

    if [ -z "$pane_id" ]; then
        echo "Refusing to send to Codex: registry has no pane id."
        return 1
    fi

    pane_session=$(tmux display-message -t "$pane_id" -p '#{session_name}' 2>/dev/null || true)
    if [ "$pane_session" != "$expected_session" ]; then
        echo "Refusing to send to Codex: pane $pane_id belongs to '${pane_session:-no live session}', not '$expected_session'."
        return 1
    fi
}

# Resolve a human target without ever silently choosing among partial matches.
# Exact tmux names win, numeric targets are positional convenience, and a
# partial name must identify exactly one provider-compatible session.
resolve_session() {
    local target="$1"
    local requested_agent="${2:-}"
    local names=()
    local matches=()
    local name provider
    mapfile -t names < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)

    if [[ "$target" =~ ^-?[0-9]+$ ]]; then
        if [[ "$target" == -* ]]; then
            echo "Session number must be positive: $target" >&2
            return 1
        fi
        local target_number=$((10#$target))
        if [ "$target_number" -le 0 ]; then
            echo "Session number must be positive: $target" >&2
            return 1
        fi
        name="${names[$((target_number - 1))]:-}"
        if [ -z "$name" ]; then
            echo "Session not found: $target" >&2
            return 1
        fi
        if [ -n "$requested_agent" ] && [ "$(provider_for_session "$name")" != "$requested_agent" ]; then
            echo "Session '$name' is not a $requested_agent session" >&2
            return 1
        fi
        echo "$name"
        return 0
    fi

    for name in "${names[@]}"; do
        if [ "$name" = "$target" ]; then
            if [ -n "$requested_agent" ] && [ "$(provider_for_session "$name")" != "$requested_agent" ]; then
                echo "Session '$name' is not a $requested_agent session" >&2
                return 1
            fi
            echo "$name"
            return 0
        fi
    done

    for name in "${names[@]}"; do
        [[ "$name" == *"$target"* ]] || continue
        provider=$(provider_for_session "$name")
        [ -z "$requested_agent" ] || [ "$provider" = "$requested_agent" ] || continue
        matches+=("$name")
    done
    if [ "${#matches[@]}" -eq 0 ]; then
        echo "Session not found: $target" >&2
        return 1
    fi
    if [ "${#matches[@]}" -ne 1 ]; then
        echo "Ambiguous session target '$target': ${matches[*]}" >&2
        return 2
    fi
    echo "${matches[0]}"
}

# Resolve an exact session name to the pane id of its active pane.
#
# tmux honours the '=' exact-match prefix only on SESSION targets (has-session,
# kill-session, attach). PANE targets — send-keys, capture-pane, display-message
# — reject "=name" outright on tmux 3.0a, which is what ships here. Pane ids are
# exact on every tmux version, so resolve the name once and target the id.
# Pass a pane id straight through.
# Resolve a SESSION NAME (never a pane id) to the pane id of its active pane.
#
# This never sniffs the string to guess what kind of object it names. tmux accepts
# '%185' as a perfectly legal SESSION name, so a "looks like a pane id" shortcut
# would send `shuttle send '%185'` into whichever session actually owns pane %185 —
# a different session entirely. Callers that genuinely hold a pane id say so by
# calling tmux_send_pane directly.
session_pane() {
    local target="$1"
    local pane owner

    # Step 1: ask tmux for the active pane of the active window.
    #
    # '11' is the active pane of the active window — exactly one row can match, even
    # when the session has several windows each with its own active pane. Only fixed
    # tokens and the pane id go through the delimiter, never the session name: tmux
    # permits '|', spaces AND the 0x1f separator itself inside a session name, so any
    # delimited field carrying a name can be split in the wrong place.
    pane=$(tmux list-panes -s -t "=$target" \
        -F "#{window_active}#{pane_active}${SEP}#{pane_id}" 2>/dev/null \
        | awk -F"$SEP" '$1 == "11" { print $2; exit }')
    [ -n "$pane" ] || return 0

    # Step 2: confirm the pane really belongs to the session we asked for.
    #
    # This is NOT redundant. Measured on tmux 3.0a: has-session and kill-session
    # honour '=', but list-panes IGNORES it and still prefix-matches, so step 1's
    # `-t "=shuttle-foo"` happily returns shuttle-foo-long's pane once shuttle-foo is
    # gone. Compare the name tmux hands back, whole and unparsed — no field splitting,
    # so a name containing the separator cannot masquerade as its own prefix.
    owner=$(tmux display-message -t "$pane" -p '#{session_name}' 2>/dev/null) || return 0
    [ "$owner" = "$target" ] || return 0
    echo "$pane"
}

# Last-activity timestamp of exactly one session.
#
# The old `grep -F "$SESSION|"` matched any session whose name ENDED with the
# target, because the '|' delimiter follows the name: with 'zzr3a' and 'xzzr3a'
# both live, `shuttle send zzr3a` got TWO lines back and died on
# `IDLE=$((NOW - ACTIVITY))` with a raw bash syntax error. Compare the name field
# exactly, and split on 0x1f so a name containing '|' can't split wrong either.
session_activity() {
    local sep="$SEP"
    # ENVIRON, not -v: awk -v processes escape sequences, so a session name containing
    # a backslash would arrive mangled and never compare equal to itself.
    tmux list-sessions -F "#{session_name}${sep}#{session_activity}" 2>/dev/null \
        | want="$1" awk -F"$sep" '$1 == ENVIRON["want"] { print $2; exit }'
}

# Working directory of a session's active pane; empty if it has none.
# Never emits a bare `-t ""` — tmux reads that as "the current session" and would
# answer with the CALLER's cwd instead of the target's.
session_cwd() {
    local pane
    pane=$(session_pane "$1")
    [ -n "$pane" ] || return 0
    tmux display-message -t "$pane" -p '#{pane_current_path}' 2>/dev/null || true
}

# Send a message to a known PANE ID and press Enter.
# Usage: tmux_send_pane <%pane-id> <message>
# NOTE: Must use two separate send-keys calls when using -t target!
# Single-line "message" Enter doesn't work reliably with -t flag.
tmux_send_pane() {
    local pane="$1"
    local message="$2"
    if [ -z "$pane" ]; then
        echo "Refusing to send: no pane id." >&2
        return 1
    fi
    tmux send-keys -t "$pane" -l -- "$message"
    sleep 0.3
    tmux send-keys -t "$pane" Enter
}

# Send a message to a SESSION (by exact name) and press Enter.
# Usage: tmux_send_cmd <session-name> <message>
tmux_send_cmd() {
    local target="$1"
    local message="$2"
    local pane
    pane=$(session_pane "$target")
    if [ -z "$pane" ]; then
        echo "Cannot send to '$target': no live pane found." >&2
        return 1
    fi
    tmux send-keys -t "$pane" -l -- "$message"
    sleep 0.3
    tmux send-keys -t "$pane" Enter
}

terminal_errors_are_dbus_stale() {
    local errors="$1"
    echo "$errors" | grep -qiE "screen|dbus|DBus|CreateInstance|Factory"
}

terminal_errors_need_warning() {
    local errors="$1"
    echo "$errors" | grep -qiE "error|failed|cannot" && ! echo "$errors" | grep -q "Falling back"
}

run_terminal_command() {
    local errfile="$1"
    shift
    local had_errexit=""

    case "$-" in
        *e*)
            had_errexit=1
            set +e
            ;;
    esac

    "$@" 2>"$errfile"
    local rc=$?

    if [ -n "$had_errexit" ]; then
        set -e
    fi

    return $rc
}

# Verify a window with the given title appeared in the X server.
# Polls for up to ~2 seconds via wmctrl or xdotool. Returns 0 if found,
# 1 if neither tool is available (treated as inconclusive, not failure),
# 2 if the tool ran but no matching window appeared.
verify_window_opened() {
    local title="$1"
    local tool=""

    if command -v wmctrl >/dev/null 2>&1; then
        tool="wmctrl"
    elif command -v xdotool >/dev/null 2>&1; then
        tool="xdotool"
    else
        return 1
    fi

    local attempts=20
    while [ $attempts -gt 0 ]; do
        if [ "$tool" = "wmctrl" ]; then
            if wmctrl -l 2>/dev/null | grep -Fq "$title"; then
                return 0
            fi
        else
            if xdotool search --name "$title" >/dev/null 2>&1; then
                return 0
            fi
        fi
        sleep 0.1
        # `attempts=$((attempts - 1))`, NOT `((attempts -= 1))`: the latter returns exit
        # status 1 when the result reaches 0, which under `set -e` silently kills shuttle
        # on the final iteration — precisely the wedged-terminal case the caller's warning
        # block exists to report, making its `return 2` and that warning unreachable.
        attempts=$((attempts - 1))
    done

    return 2
}

# Launch terminal with given command argv.
# Args: $1 = window title, remaining args = command argv to run inside terminal.
launch_terminal() {
    local title="${1:-shuttle}"
    shift || true
    if [ "$#" -eq 0 ]; then
        echo "launch_terminal requires a command" >&2
        return 1
    fi
    local attach_target=""
    local previous_arg=""
    local arg
    for arg in "$@"; do
        if [ "$previous_arg" = "-t" ]; then
            attach_target="$arg"
            break
        fi
        previous_arg="$arg"
    done
    local errfile
    errfile=$(mktemp /tmp/shuttle-term-XXXXXX)

    # Unset GNOME_TERMINAL_{SCREEN,SERVICE} before invoking gnome-terminal.
    # These vars are set inside a running gnome-terminal so child shells can
    # attach to the same screen. If shuttle was launched from a gnome-terminal
    # that has since closed (or the server restarted), the inherited screen
    # path is dead — every new gnome-terminal client will fail with
    # "Failed to get screen from object path ..." even though the server is
    # perfectly healthy. Stripping the vars forces a fresh screen.
    run_terminal_command "$errfile" env -u GNOME_TERMINAL_SCREEN -u GNOME_TERMINAL_SERVICE gnome-terminal --title "$title" -- "$@"
    local rc=$?
    local used_fallback=""

    if [ $rc -ne 0 ] || [ -s "$errfile" ]; then
        local errors
        errors=$(cat "$errfile")

        if terminal_errors_are_dbus_stale "$errors"; then
            if command -v xterm >/dev/null 2>&1; then
                : >"$errfile"
                run_terminal_command "$errfile" xterm -T "$title" -e "$@"
                rc=$?
                errors=$(cat "$errfile")
                used_fallback=1
            else
                rm -f "$errfile"
                echo "Terminal launch failed and xterm fallback unavailable."
                echo "Try 'shuttle doctor' to diagnose; common cause is a stale"
                echo "GNOME_TERMINAL_SCREEN env var (should be auto-unset, file a bug)."
                echo "Session is still running in tmux — attach manually"
                return 1
            fi
        fi

        rm -f "$errfile"
        # Only warn on real errors, not GTK noise or fallback messages
        if { [ $rc -ne 0 ] || [ -n "$errors" ]; } && terminal_errors_need_warning "$errors"; then
            echo "Warning: terminal launch may have failed:"
            echo "  $errors"
            echo "Session is still running in tmux — attach manually"
        fi
    else
        rm -f "$errfile"
    fi

    # Post-launch verification: gnome-terminal-server returns rc=0 instantly via fork,
    # so an exit code alone tells us nothing about whether a window actually appeared.
    # If wmctrl or xdotool is available, confirm the window exists.
    if [ -z "$used_fallback" ] && [ -z "$SHUTTLE_SKIP_WINDOW_CHECK" ]; then
        verify_window_opened "$title"
        local vrc=$?
        if [ $vrc -eq 2 ]; then
            echo "Warning: gnome-terminal returned success but no window titled '$title' appeared."
            echo "  gnome-terminal-server may be wedged. Try 'shuttle doctor' to diagnose."
            if [ -n "$attach_target" ]; then
                echo "  Session is still running in tmux — attach with: tmux attach -t $attach_target"
            else
                echo "  Session is still running in tmux — attach manually"
            fi
            return 1
        fi
    fi

    return 0
}

# Format seconds as relative time with minutes precision (e.g., "2m", "3h 42m")
format_age() {
    local seconds=$1
    if [ "$seconds" -lt 60 ]; then
        echo "${seconds}s"
    elif [ "$seconds" -lt 3600 ]; then
        echo "$((seconds / 60))m"
    elif [ "$seconds" -lt 86400 ]; then
        local hours=$((seconds / 3600))
        local mins=$(((seconds % 3600) / 60))
        if [ "$mins" -eq 0 ]; then
            echo "${hours}h"
        else
            echo "${hours}h ${mins}m"
        fi
    else
        echo "$((seconds / 86400))d"
    fi
}

# Detect Claude Code session state from pane content
detect_session_state() {
    local session="$1"
    local idle_seconds="$2"

    # Capture last 30 lines from the pane
    local pane content
    pane=$(session_pane "$session")
    content=""
    if [ -n "$pane" ]; then
        content=$(tmux capture-pane -t "$pane" -p 2>/dev/null | tail -30)
    fi

    if [ -z "$content" ]; then
        echo "unknown"
        return
    fi

    # Check for approval prompt (highest priority - needs human action)
    # Patterns: "Do you want to proceed?", "❯ 1. Yes", "Allow once", "Allow always"
    if echo "$content" | grep -qE "Do you want to proceed\?|❯ 1\. Yes|Allow once|Allow always"; then
        echo "approval"
        return
    fi

    # Check for tool currently running (shows "Running…" after tool name)
    # Pattern: "⎿  Running…" or similar indented Running indicator
    if echo "$content" | grep -qE "Running…"; then
        echo "running"
        return
    fi

    # Check for thinking/processing state (before tool execution)
    # Pattern: "✻ Verb…" or "✶ Verb…" with "(esc to interrupt)"
    # These are Claude's animated "thinking" indicators like "✻ Noodling…", "✻ Pondering…"
    if echo "$content" | grep -qE "✶ [A-Za-z].*…|✻ [A-Za-z].*…|esc to interrupt"; then
        echo "thinking"
        return
    fi

    # Check for waiting at prompt (> or ❯ character with trailing space)
    # Anchored pattern prevents false matches in quoted diff output
    if echo "$content" | tail -5 | grep -qE "^> $|^❯ $"; then
        echo "waiting"
        return
    fi

    # Check for stuck (idle for more than 5 minutes with no clear state)
    if [ "$idle_seconds" -gt 300 ]; then
        echo "stuck"
        return
    fi

    echo "unknown"
}

# Format state with symbol
format_state() {
    local state="$1"
    case "$state" in
        running)  echo "⏳" ;;  # Tool is running (waiting for output)
        starting) echo "⏳" ;;
        thinking) echo "🧠" ;;  # Claude is thinking/processing (before tool call)
        working)  echo "🧠" ;;
        approval) echo "🔒" ;;  # Waiting for user permission
        waiting)  echo "💤" ;;  # At prompt, waiting for input
        idle)     echo "💤" ;;
        dead|stale) echo "⚠️ " ;;
        stuck)    echo "⚠️ " ;; # Idle too long with unclear state
        *)        echo "○" ;;   # Unknown state
    esac
}

CMD="${1:-status}"
shift 2>/dev/null || true

case "$CMD" in
    status)
        STATUS_AGENT=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --agent)
                    STATUS_AGENT="$2"
                    validate_agent "$STATUS_AGENT"
                    shift 2
                    ;;
                *)
                    echo "Usage: shuttle status [--agent claude|codex]"
                    exit 1
                    ;;
            esac
        done
        # Start slow skein calls in parallel
        BRIEFS_TMP=$(mktemp)
        SHARDS_TMP=$(mktemp)
        trap "rm -f $BRIEFS_TMP $SHARDS_TMP" EXIT

        (skein folios "$SHUTTLE_DEFAULT_SITE" --type brief --status open 2>/dev/null | grep "brief-" | head -5 > "$BRIEFS_TMP") &
        BRIEFS_PID=$!
        (skein shard triage 2>/dev/null | tail -n +3 > "$SHARDS_TMP") &
        SHARDS_PID=$!

        # Sessions with activity info
        echo "SESSIONS:"
        NOW=$(date +%s)
        # 0x1f, not '|': tmux permits '|' in a session name, which truncated NAME (so
        # provider_for_session looked up the wrong session and the launch was printed a
        # second time as a phantom stale row) and could feed junk into the arithmetic
        # below, aborting a bare `shuttle` under `set -e`. Same defect round 3 removed
        # from send/relay; status was the one left behind.
        SESSIONS=$(tmux list-sessions -F "#{session_name}${SEP}#{session_attached}${SEP}#{session_activity}" 2>/dev/null || true)
        declare -A SEEN_SESSIONS=()
        if [ -z "$SESSIONS" ]; then
            :
        else
            i=1
            while IFS="$SEP" read -r NAME ATTACHED ACTIVITY; do
                PROVIDER=$(provider_for_session "$NAME")
                if [ -n "$STATUS_AGENT" ] && [ "$PROVIDER" != "$STATUS_AGENT" ]; then
                    ((i++))
                    continue
                fi
                SEEN_SESSIONS["$NAME"]=1
                # Belt and braces: whatever separator we pick, tmux permits it inside a
                # session name, so a foreign name could still split into junk fields.
                # Validate before arithmetic — a non-numeric ACTIVITY or ATTACHED would
                # otherwise abort a bare `shuttle` under `set -e`. Treat junk as 0/detached.
                [[ "$ACTIVITY" =~ ^[0-9]+$ ]] || ACTIVITY="$NOW"
                [[ "$ATTACHED" =~ ^[0-9]+$ ]] || ATTACHED=0
                IDLE=$((NOW - ACTIVITY))
                AGE=$(format_age $IDLE)
                if [ "$ATTACHED" -eq 1 ]; then
                    ATTACH_STR="attached"
                else
                    ATTACH_STR="detached"
                fi
                RECORD=$(record_for_session "$NAME" || true)
                if [ -n "$RECORD" ]; then
                    IFS=$'\x1f' read -r -a RECORD_FIELDS <<< "$RECORD"
                    STATE="${RECORD_FIELDS[2]}"
                    PID="${RECORD_FIELDS[5]}"
                    PROCESS_STR="dead"
                    if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
                        PROCESS_STR="live"
                    fi
                    EXISTENCE="session=live process=$PROCESS_STR"
                    if [ "$PROVIDER" = "claude" ]; then
                        STATE=$(detect_session_state "$NAME" "$IDLE")
                    fi
                else
                    STATE=$(detect_session_state "$NAME" "$IDLE")
                    EXISTENCE="session=live process=unknown"
                fi
                INDICATOR=$(format_state "$STATE")
                printf "  [%d] %-30s [%s] (%s; %s) %4s %s %s\n" "$i" "$NAME" "$PROVIDER" "$ATTACH_STR" "$EXISTENCE" "$AGE" "$INDICATOR" "$STATE"
                ((i++))
            done <<< "$SESSIONS"
        fi

        LIVE_RECORDS=$(registry_cli records --live 2>/dev/null || true)
        while IFS= read -r REGISTRY_LINE; do
            IFS=$'\x1f' read -r -a RECORD_FIELDS <<< "$REGISTRY_LINE"
            PROVIDER="${RECORD_FIELDS[1]:-}"
            STATE="${RECORD_FIELDS[2]:-}"
            NAME="${RECORD_FIELDS[3]:-}"
            PID="${RECORD_FIELDS[5]:-}"
            [ -n "$NAME" ] || continue
            [ -z "$STATUS_AGENT" ] || [ "$PROVIDER" = "$STATUS_AGENT" ] || continue
            [ -z "${SEEN_SESSIONS[$NAME]:-}" ] || continue
            PROCESS_STR="dead"
            if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
                PROCESS_STR="live"
            fi
            INDICATOR=$(format_state "stale")
            printf "  [-] %-30s [%s] (session=dead; process=%s)    %s stale (registry: %s)\n" "$NAME" "$PROVIDER" "$PROCESS_STR" "$INDICATOR" "$STATE"
        done <<< "$LIVE_RECORDS"
        if [ -z "$SESSIONS" ] && [ -z "$LIVE_RECORDS" ]; then
            echo "  (none)"
        fi
        echo ""

        # Wait for briefs and display
        wait $BRIEFS_PID 2>/dev/null
        echo "READY BRIEFS:"
        if [ -s "$BRIEFS_TMP" ]; then
            while read -r line; do
                echo "  $line"
            done < "$BRIEFS_TMP"
        else
            echo "  (none)"
        fi
        echo ""

        # Wait for shards and display
        wait $SHARDS_PID 2>/dev/null
        echo "SHARDS:"
        TRIAGE=$(cat "$SHARDS_TMP")
        if [ -z "$TRIAGE" ]; then
            echo "  (unavailable)"
        else
            READY=$(echo "$TRIAGE" | grep -c "✓" 2>/dev/null || true)
            CONFLICT=$(echo "$TRIAGE" | grep -c "⚠" 2>/dev/null || true)
            EMPTY=$(echo "$TRIAGE" | grep -c "empty" 2>/dev/null || true)
            echo "  ${READY:-0} ready, ${CONFLICT:-0} conflicts, ${EMPTY:-0} empty"
        fi
        ;;

    ls|list)
        tmux ls 2>/dev/null | nl -w2 -s'] ' | sed 's/^/[/' || echo "(no sessions)"
        ;;

    board|b)
        # Check for --headless flag
        HEADLESS=""
        TARGET=""
        AGENT=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --headless) HEADLESS=1; shift ;;
                --agent) AGENT="$2"; validate_agent "$AGENT"; shift 2 ;;
                *) TARGET="$1"; shift ;;
            esac
        done
        # Also check env var and display
        if [ -n "$SHUTTLE_HEADLESS" ] || [ -z "$DISPLAY" ]; then
            HEADLESS=1
        fi

        if [ -z "$TARGET" ]; then
            echo "Usage: shuttle board [--headless] <number|name>"
            exit 1
        fi

        SESSION=$(resolve_session "$TARGET" "$AGENT") || exit $?

        echo "Boarding $SESSION..."
        if [ -n "$HEADLESS" ]; then
            tmux attach -t "=$SESSION"
        else
            launch_terminal "shuttle:$SESSION" tmux attach -t "=$SESSION"
        fi
        ;;

    kill|k)
        AGENT=""
        TARGET=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --agent) AGENT="$2"; validate_agent "$AGENT"; shift 2 ;;
                *) TARGET="$1"; shift ;;
            esac
        done
        if [ -z "$TARGET" ]; then
            echo "Usage: shuttle kill [--agent claude|codex] <number|name>"
            exit 1
        fi
        SESSION=$(resolve_session "$TARGET" "$AGENT") || exit $?

        echo "Killing $SESSION..."
        tmux kill-session -t "=$SESSION"
        echo "Done."
        ;;

    send)
        # Parse options
        FORCE_SEND=""
        WAIT_FOR_PROMPT=""
        AGENT=""
        POSITIONAL=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --force|-f)
                    FORCE_SEND=1
                    shift
                    ;;
                --wait|-w)
                    WAIT_FOR_PROMPT=1
                    shift
                    ;;
                --agent)
                    AGENT="$2"
                    validate_agent "$AGENT"
                    shift 2
                    ;;
                *)
                    POSITIONAL+=("$1")
                    shift
                    ;;
            esac
        done
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ] || [ -z "$2" ]; then
            echo "Usage: shuttle send [--force] [--wait] <number|name> <message>"
            echo "  --force, -f   Send even if session is not at prompt"
            echo "  --wait, -w    Wait for prompt before sending (up to 30s)"
            exit 1
        fi

        TARGET="$1"
        MESSAGE="$2"

        SESSION=$(resolve_session "$TARGET" "$AGENT") || exit $?
        PROVIDER=$(provider_for_session "$SESSION")

        # Check session state before sending
        if [ "$PROVIDER" = "codex" ]; then
            load_codex_send_record "$SESSION"
            STATE="$CODEX_STATE"
        else
            NOW=$(date +%s)
            ACTIVITY=$(session_activity "$SESSION")
            IDLE=$((NOW - ACTIVITY))
            STATE=$(detect_session_state "$SESSION" "$IDLE")
        fi

        if [ -n "$WAIT_FOR_PROMPT" ]; then
            # Wait for session to reach prompt state (use configured timeout)
            WAIT_ITERATIONS=$((SHUTTLE_PROMPT_TIMEOUT * 2))  # 2 checks per second
            echo "Waiting for $SESSION to reach prompt..."
            for ((i=1; i<=WAIT_ITERATIONS; i++)); do
                ACTIVITY=$(session_activity "$SESSION")
                # Detect session disappearance
                if [ -z "$ACTIVITY" ]; then
                    echo "Error: Session '$SESSION' no longer exists"
                    exit 1
                fi
                if [ "$PROVIDER" = "codex" ]; then
                    load_codex_send_record "$SESSION"
                    STATE="$CODEX_STATE"
                else
                    NOW=$(date +%s)
                    IDLE=$((NOW - ACTIVITY))
                    STATE=$(detect_session_state "$SESSION" "$IDLE")
                fi
                if { [ "$PROVIDER" = "codex" ] && [ "$STATE" = "idle" ]; } || { [ "$PROVIDER" = "claude" ] && [ "$STATE" = "waiting" ]; }; then
                    break
                fi
                sleep 0.5
            done
            if { [ "$PROVIDER" = "codex" ] && [ "$STATE" != "idle" ]; } || { [ "$PROVIDER" = "claude" ] && [ "$STATE" != "waiting" ]; }; then
                echo "Warning: Timed out waiting for prompt (state: $STATE)"
                if [ -z "$FORCE_SEND" ] || [ "$PROVIDER" = "codex" ]; then
                    echo "Use --force to send anyway"
                    exit 1
                fi
            fi
        fi

        # Warn if not at prompt (unless forced)
        if [ "$PROVIDER" = "codex" ] && [ "$STATE" != "idle" ]; then
            echo "Refusing to send to Codex while registry state is '$STATE'."
            echo "Codex send requires a confirmed idle state; --force cannot override it."
            exit 1
        fi
        if [ "$PROVIDER" = "claude" ] && [ "$STATE" != "waiting" ] && [ -z "$FORCE_SEND" ]; then
            INDICATOR=$(format_state "$STATE")
            echo "Warning: Session is not at prompt ($INDICATOR $STATE)"
            case "$STATE" in
                working)
                    echo "  Claude is currently processing. The message may be ignored."
                    ;;
                approval)
                    echo "  Session is waiting for approval. Send may interact with the approval prompt."
                    ;;
                stuck)
                    echo "  Session appears stuck. The message may not be received."
                    ;;
            esac
            echo "Use --force to send anyway, or --wait to wait for prompt"
            exit 1
        fi

        SEND_PANE=""
        if [ "$PROVIDER" = "codex" ]; then
            load_codex_send_record "$SESSION"
            STATE="$CODEX_STATE"
            if [ "$STATE" != "idle" ]; then
                echo "Refusing to send to Codex while registry state is '$STATE'."
                echo "Codex send requires a confirmed idle state; --force cannot override it."
                exit 1
            fi
            verify_codex_send_pane "$SESSION" "$CODEX_PANE_ID" || exit $?
            SEND_PANE="$CODEX_PANE_ID"
        fi
        echo "Sending to $SESSION: $MESSAGE"
        # Codex sends to the registry's verified pane id; Claude sends by session name.
        # The distinction is explicit — never inferred from the string's shape.
        if [ -n "$SEND_PANE" ]; then
            tmux_send_pane "$SEND_PANE" "$MESSAGE"
        else
            tmux_send_cmd "$SESSION" "$MESSAGE"
        fi

        # Brief verification that something happened
        sleep 0.3
        if [ "$PROVIDER" = "codex" ]; then
            NEW_STATE="unknown"
            RECORD=$(record_for_session "$SESSION" || true)
            if [ -n "$RECORD" ]; then
                IFS=$'\x1f' read -r -a RECORD_FIELDS <<< "$RECORD"
                NEW_STATE="${RECORD_FIELDS[2]}"
            fi
        else
            NEW_STATE=$(detect_session_state "$SESSION" 0)
        fi
        case "$NEW_STATE" in
            working)
                echo "✓ Claude is processing your message"
                ;;
            waiting)
                if [ "$STATE" = "waiting" ]; then
                    echo "Note: Session still at prompt - message may not have been accepted"
                else
                    echo "✓ Message sent, session now at prompt"
                fi
                ;;
            approval)
                echo "Note: Session is now awaiting approval"
                ;;
            stuck)
                echo "Warning: Session appears stuck after send"
                ;;
            unknown)
                echo "Note: Could not determine session state after send"
                ;;
        esac
        ;;

    relay)
        claude_only_args relay "$@"
        set -- "${CLAUDE_ARGS[@]}"
        NO_ENTER=""
        FORCE_SEND=""
        WAIT_FOR_PROMPT=""
        POSITIONAL=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --no-enter|-n)
                    NO_ENTER=1
                    shift
                    ;;
                --force|-f)
                    FORCE_SEND=1
                    shift
                    ;;
                --wait|-w)
                    WAIT_FOR_PROMPT=1
                    shift
                    ;;
                *)
                    POSITIONAL+=("$1")
                    shift
                    ;;
            esac
        done
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ] || [ -z "$2" ]; then
            echo "Usage: shuttle relay [options] <number|name> <file|->"
            echo "  --no-enter, -n  Paste without pressing Enter"
            echo "  --force, -f     Send even if session is not at prompt"
            echo "  --wait, -w      Wait for prompt before sending (up to 30s)"
            echo "  Use '-' to read from stdin"
            exit 1
        fi

        TARGET="$1"
        FILE="$2"

        SESSION=$(resolve_session "$TARGET" "claude") || exit $?

        # Read content from file or stdin
        if [ "$FILE" = "-" ]; then
            CONTENT=$(cat)
        elif [ ! -f "$FILE" ]; then
            echo "File not found: $FILE"
            exit 1
        else
            CONTENT=$(cat "$FILE")
        fi

        # Check size (warn if > 10KB)
        SIZE=${#CONTENT}
        if [ "$SIZE" -gt 10240 ]; then
            echo "Warning: Large content ($SIZE bytes) - may be slow"
        fi

        # Check session state before sending
        NOW=$(date +%s)
        ACTIVITY=$(session_activity "$SESSION")
        IDLE=$((NOW - ACTIVITY))
        STATE=$(detect_session_state "$SESSION" "$IDLE")

        if [ -n "$WAIT_FOR_PROMPT" ]; then
            # Wait for session to reach prompt state (use configured timeout)
            WAIT_ITERATIONS=$((SHUTTLE_PROMPT_TIMEOUT * 2))  # 2 checks per second
            echo "Waiting for $SESSION to reach prompt..."
            for ((i=1; i<=WAIT_ITERATIONS; i++)); do
                NOW=$(date +%s)
                ACTIVITY=$(session_activity "$SESSION")
                # Detect session disappearance
                if [ -z "$ACTIVITY" ]; then
                    echo "Error: Session '$SESSION' no longer exists"
                    exit 1
                fi
                IDLE=$((NOW - ACTIVITY))
                STATE=$(detect_session_state "$SESSION" "$IDLE")
                if [ "$STATE" = "waiting" ]; then
                    break
                fi
                sleep 0.5
            done
            if [ "$STATE" != "waiting" ]; then
                echo "Warning: Timed out waiting for prompt (state: $STATE)"
                if [ -z "$FORCE_SEND" ]; then
                    echo "Use --force to send anyway"
                    exit 1
                fi
            fi
        fi

        # Warn if not at prompt (unless forced)
        if [ "$STATE" != "waiting" ] && [ -z "$FORCE_SEND" ]; then
            INDICATOR=$(format_state "$STATE")
            echo "Warning: Session is not at prompt ($INDICATOR $STATE)"
            echo "Use --force to send anyway, or --wait to wait for prompt"
            exit 1
        fi

        echo "Relaying to $SESSION ($SIZE bytes)..."
        if [ -n "$NO_ENTER" ]; then
            RELAY_PANE=$(session_pane "$SESSION")
            if [ -z "$RELAY_PANE" ]; then
                echo "Cannot relay to '$SESSION': no live pane found." >&2
                exit 1
            fi
            tmux send-keys -t "$RELAY_PANE" -l -- "$CONTENT"
        else
            tmux_send_cmd "$SESSION" "$CONTENT"
        fi
        echo "Done."
        ;;

    context|ctx)
        claude_only_args context "$@"
        set -- "${CLAUDE_ARGS[@]}"
        TARGET="${1:-1}"
        LAST_N="${2:-10}"

        # One funnel for human target -> tmux session, same as peek/send/relay:
        # exact name wins, a partial must identify exactly one session, ambiguity is
        # an error. The old `tmux ls | grep "$TARGET" | head -1` took a substring's
        # FIRST hit with no ambiguity check, so `tail auth` could stream `a-auth`
        # even when a session named exactly `auth` was live.
        SESSION=$(resolve_session "$TARGET") || exit $?

        # Get session's working directory
        CWD=$(session_cwd "$SESSION")
        if [ -z "$CWD" ]; then
            echo "Could not get session working directory"
            exit 1
        fi

        # Convert to CC's project path format: /home/patrick/foo → -home-patrick-foo
        PROJECT_PATH=$(echo "$CWD" | sed 's|^/||; s|/|-|g; s|^|-|')
        CC_PROJECT_DIR="$HOME/.claude/projects/$PROJECT_PATH"

        if [ ! -d "$CC_PROJECT_DIR" ]; then
            echo "No CC history found for: $CWD"
            exit 1
        fi

        # Find most recent session file (excluding agent- files which are subagents)
        SESSION_FILE=$(ls -t "$CC_PROJECT_DIR"/*.jsonl 2>/dev/null | grep -v '/agent-' | head -1)
        if [ -z "$SESSION_FILE" ]; then
            echo "No session files found"
            exit 1
        fi

        echo "=== $SESSION context (last $LAST_N messages) ==="
        echo "=== from: $(basename "$SESSION_FILE") ==="
        echo ""

        # Extract and format messages
        tail -n "$LAST_N" "$SESSION_FILE" | while IFS= read -r line; do
            TYPE=$(echo "$line" | jq -r '.type // "unknown"' 2>/dev/null)
            ROLE=$(echo "$line" | jq -r '.message.role // ""' 2>/dev/null)

            if [ "$TYPE" = "user" ] && [ "$ROLE" = "user" ]; then
                # User content can be string or array - extract text, skip tool_results
                CONTENT=$(echo "$line" | jq -r '
                    .message.content |
                    if type == "string" then .
                    elif type == "array" then
                        [.[] | select(.type == "text") | .text] | join("\n")
                    else ""
                    end
                ' 2>/dev/null)
                if [ -n "$CONTENT" ] && [ "$CONTENT" != "null" ]; then
                    echo "USER: $CONTENT"
                    echo ""
                fi
            elif [ "$TYPE" = "assistant" ] && [ "$ROLE" = "assistant" ]; then
                # Get text content from assistant (skip tool use blocks)
                CONTENT=$(echo "$line" | jq -r '
                    [.message.content[] | select(.type == "text") | .text] | join("\n")
                ' 2>/dev/null | head -c 800)
                if [ -n "$CONTENT" ] && [ "$CONTENT" != "null" ]; then
                    echo "CLAUDE: $CONTENT"
                    echo ""
                fi
            fi
        done
        ;;

    search)
        claude_only_args search "$@"
        set -- "${CLAUDE_ARGS[@]}"
        SHUTTLE_INDEX_FILE="$HOME/.shuttle/index.json"
        CC_PROJECTS="$HOME/.claude/projects"

        # Parse options
        QUERY=""
        SEARCH_ALL=""
        LIST_MODE=""
        SINCE_FILTER=""
        PROJECT_FILTER=""
        LIMIT=20

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --all|-a)
                    SEARCH_ALL=1
                    shift
                    ;;
                --list|-l)
                    LIST_MODE=1
                    shift
                    ;;
                --since|-s)
                    SINCE_FILTER="$2"
                    shift 2
                    ;;
                --project|-p)
                    PROJECT_FILTER="$2"
                    shift 2
                    ;;
                --limit|-n)
                    LIMIT="$2"
                    shift 2
                    ;;
                -*)
                    echo "Unknown option: $1"
                    echo "Usage: shuttle search [query] [options]"
                    echo "  --all, -a        Search all projects (default: current project)"
                    echo "  --list, -l       List sessions from index (no content search)"
                    echo "  --since, -s N    Only sessions from last N days"
                    echo "  --project, -p P  Filter by project path (substring match)"
                    echo "  --limit, -n N    Limit results (default: 20)"
                    exit 1
                    ;;
                *)
                    QUERY="$1"
                    shift
                    ;;
            esac
        done

        # Check if index exists
        if [ ! -f "$SHUTTLE_INDEX_FILE" ]; then
            echo "No index found. Run 'shuttle index' first."
            exit 1
        fi

        # Build jq filter for index queries
        JQ_FILTER='.sessions | to_entries[]'

        # Project filter
        if [ -n "$PROJECT_FILTER" ]; then
            JQ_FILTER="$JQ_FILTER | select(.value.project | contains(\"$PROJECT_FILTER\"))"
        elif [ -z "$SEARCH_ALL" ]; then
            # Default: current project
            CURRENT_PROJECT=$(pwd)
            JQ_FILTER="$JQ_FILTER | select(.value.project | startswith(\"$CURRENT_PROJECT\"))"
        fi

        # Date filter
        if [ -n "$SINCE_FILTER" ]; then
            SINCE_EPOCH=$(($(date +%s) - (SINCE_FILTER * 86400)))
            JQ_FILTER="$JQ_FILTER | select(.value.mtime >= $SINCE_EPOCH)"
        fi

        # Sort by last activity (most recent first)
        JQ_FILTER="[$JQ_FILTER] | sort_by(.value.mtime) | reverse"

        # Limit results
        JQ_FILTER="$JQ_FILTER | .[:$LIMIT]"

        if [ -n "$LIST_MODE" ]; then
            # List mode: show sessions from index without content search
            echo "Sessions from index:"
            echo ""
            # Use tab delimiter for safe parsing
            jq -r "$JQ_FILTER | .[] | \"\(.key)\t\(.value.mtime)\t\(.value.project)\t\(.value.summary[0:50] | gsub(\"[\\n\\t]\"; \" \"))\"" "$SHUTTLE_INDEX_FILE" 2>/dev/null | while IFS=$'\t' read -r ID MTIME PROJECT SUMMARY; do
                NOW=$(date +%s)
                AGE=$(( (NOW - MTIME) / 86400 ))
                if [ "$AGE" -eq 0 ]; then
                    AGE_STR="today"
                elif [ "$AGE" -eq 1 ]; then
                    AGE_STR="1d ago"
                else
                    AGE_STR="${AGE}d ago"
                fi
                # Extract just project name
                PROJ_NAME=$(basename "$PROJECT")
                printf "%-38s %-10s %-15s %s\n" "$ID" "$AGE_STR" "$PROJ_NAME" "$SUMMARY"
            done
        else
            # Content search: use index to get files, then grep
            if [ -z "$QUERY" ]; then
                echo "Usage: shuttle search <query> [options]"
                echo "  Or use --list to list sessions without searching content"
                exit 1
            fi

            echo "Searching for: $QUERY"
            echo ""

            # Get files from index, then grep them
            jq -r "$JQ_FILTER | .[].value.file" "$SHUTTLE_INDEX_FILE" 2>/dev/null | while read -r FILE; do
                if [ ! -f "$FILE" ]; then
                    continue
                fi

                if ! grep -q "$QUERY" "$FILE" 2>/dev/null; then
                    continue
                fi

                SESSION_ID=$(basename "$FILE" .jsonl)
                PROJECT=$(jq -r ".sessions[\"$SESSION_ID\"].project" "$SHUTTLE_INDEX_FILE" 2>/dev/null)

                # Get file modification time (cross-platform)
                MOD_TIME=$(stat -c %Y "$FILE" 2>/dev/null || stat -f %m "$FILE" 2>/dev/null || echo 0)
                NOW=$(date +%s)
                AGE=$(( (NOW - MOD_TIME) / 86400 ))
                if [ "$AGE" -eq 0 ]; then
                    AGE_STR="today"
                elif [ "$AGE" -eq 1 ]; then
                    AGE_STR="yesterday"
                else
                    AGE_STR="${AGE}d ago"
                fi

                echo "=== $SESSION_ID ($AGE_STR) ==="
                echo "    project: $PROJECT"

                # Show matching lines with context (text content only)
                grep "$QUERY" "$FILE" 2>/dev/null | head -3 | while read -r line; do
                    TEXT=$(echo "$line" | jq -r '
                        .message.content |
                        if type == "string" then .
                        elif type == "array" then
                            [.[] | select(.type == "text") | .text] | join(" ")
                        else ""
                        end
                    ' 2>/dev/null | head -c 200)
                    if [ -n "$TEXT" ] && [ "$TEXT" != "null" ]; then
                        echo "    ...$TEXT..."
                    fi
                done
                echo ""
            done
        fi
        ;;

    resume)
        AGENT=""
        HEADLESS=""
        PROJECT_DIR=""
        HANDOFF=""
        POSITIONAL=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --agent) AGENT="$2"; validate_agent "$AGENT"; shift 2 ;;
                --headless) HEADLESS=1; shift ;;
                -d|--dir) PROJECT_DIR="$2"; shift 2 ;;
                -p|--project) PROJECT_DIR="$HOME/projects/$2"; shift 2 ;;
                --handoff) HANDOFF="HANDOFF: $2"; shift 2 ;;
                *) POSITIONAL+=("$1"); shift ;;
            esac
        done
        SESSION_ID="${POSITIONAL[0]:-}"
        PROMPT="${POSITIONAL[1]:-$HANDOFF}"
        if [ -z "$SESSION_ID" ]; then
            echo "Usage: shuttle resume [--agent claude|codex] [--handoff BRIEF] <session-id> [prompt]"
            exit 1
        fi

        METADATA=$(registry_cli lookup-native "$SESSION_ID" 2>/dev/null || true)
        if [ -n "$METADATA" ]; then
            IFS=$'\x1f' read -r -a META_FIELDS <<< "$METADATA"
            META_PROVIDER="${META_FIELDS[1]}"
            META_STATE="${META_FIELDS[2]}"
            META_TMUX="${META_FIELDS[3]}"
            META_CWD="${META_FIELDS[6]}"
            META_BRIEF="${META_FIELDS[7]}"
            META_TITLE="${META_FIELDS[8]}"
            if [ -n "$AGENT" ] && [ "$AGENT" != "$META_PROVIDER" ]; then
                echo "Session $SESSION_ID belongs to provider $META_PROVIDER, not $AGENT"
                exit 1
            fi
            AGENT="$META_PROVIDER"
            [ -n "$PROJECT_DIR" ] || PROJECT_DIR="$META_CWD"
            if [ "$META_STATE" != "closed" ] && [ -n "$META_TMUX" ] && tmux has-session -t "=$META_TMUX" 2>/dev/null; then
                # Never interpolate an unchecked pane id: tmux reads an empty -t as
                # "the current session", so a session that dies right after the
                # has-session check would otherwise be judged by the CALLER's session.
                RESUME_PANE=$(session_pane "$META_TMUX")
                ATTACHED=0
                if [ -n "$RESUME_PANE" ]; then
                    ATTACHED=$(tmux display-message -p -t "$RESUME_PANE" '#{session_attached}' 2>/dev/null || echo 0)
                fi
                if [ "${ATTACHED:-0}" -gt 0 ]; then
                    echo "Refusing to resume: $META_TMUX is already live and attached"
                    exit 1
                fi
                echo "Session is already live and detached: $META_TMUX"
                echo "Attach with: tmux attach -t $META_TMUX"
                exit 0
            fi
        fi

        if [ -z "$AGENT" ]; then
            CC_PROJECTS="$HOME/.claude/projects"
            SESSION_FILE=$(find "$CC_PROJECTS" -name "${SESSION_ID}.jsonl" -type f 2>/dev/null | head -1)
            if [ -z "$SESSION_FILE" ]; then
                echo "Unknown session identity: $SESSION_ID"
                echo "Raw Codex UUIDs require: shuttle resume --agent codex $SESSION_ID"
                exit 1
            fi
            AGENT="claude"
        fi

        if [ "$AGENT" = "claude" ]; then
            CC_PROJECTS="$HOME/.claude/projects"
            SESSION_FILE=$(find "$CC_PROJECTS" -name "${SESSION_ID}.jsonl" -type f 2>/dev/null | head -1)
            if [ -z "$SESSION_FILE" ]; then
                echo "Claude session not found: $SESSION_ID"
                exit 1
            fi
            if [ -z "$PROJECT_DIR" ]; then
                ENCODED_PATH=$(basename "$(dirname "$SESSION_FILE")")
                PROJECT_DIR="/$(echo "$ENCODED_PATH" | sed 's/^-//; s/-/\//g')"
            fi
            PROJECT_NAME=$(basename "$PROJECT_DIR")
            # safe_session_name is mandatory: tmux REJECTS '.' and ':' in a session
            # name, and a project basename routinely has a dot (~/.mill, any foo.bar
            # repo, a dotfiles dir), which would make resume die on tmux's raw
            # "bad session name" with no shuttle-level message. Same scrub the codex
            # branch and `go` already apply.
            TMUX_SESSION="resume-$(safe_session_name "${PROJECT_NAME}-${SESSION_ID:0:8}")"
            CLAUDE_COMMAND=(claude --resume "$SESSION_ID")
            [ -z "$PROMPT" ] || CLAUDE_COMMAND+=("$PROMPT")
            printf -v RESUME_COMMAND '%q ' "${CLAUDE_COMMAND[@]}"
            run_tmux_new_session "$TMUX_SESSION" "$PROJECT_DIR" "$RESUME_COMMAND"
            if [ "$TMUX_NEW_SESSION_RC" -ne 0 ]; then
                exit "$TMUX_NEW_SESSION_RC"
            fi
        else
            [ -n "$PROJECT_DIR" ] || PROJECT_DIR="$(pwd)"
            TITLE="${META_TITLE:-resume-${SESSION_ID:0:8}}"
            TITLE=$(echo "$TITLE" | tr ' ' '-' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g' | sed 's/--*/-/g' | cut -c1-25)
            TMUX_SESSION="shuttle-codex-$(safe_session_name "${TITLE:-resume-${SESSION_ID:0:8}}")"
            if tmux has-session -t "=$TMUX_SESSION" 2>/dev/null; then
                echo "Session already exists: $TMUX_SESSION"
                exit 1
            fi
            PROVIDER_VERSION=$(codex --version 2>/dev/null | head -1 | awk '{print $NF}' || true)
            # '=' form throughout: a stored title like '-foo' would otherwise be read
            # as a flag by argparse and kill the resume under `set -e`.
            CREATE_ARGS=(create --provider=codex "--provider-version=${PROVIDER_VERSION:-unknown}" --mode=resume "--cwd=$PROJECT_DIR" "--tmux-session=$TMUX_SESSION" "--resume-of=$SESSION_ID")
            [ -z "${META_BRIEF:-}" ] || CREATE_ARGS+=("--brief=$META_BRIEF")
            [ -z "${META_TITLE:-}" ] || CREATE_ARGS+=("--title=$META_TITLE")
            if ! LAUNCH_ID=$(registry_cli "${CREATE_ARGS[@]}"); then
                echo "Error: could not register the resumed launch in the Shuttle session registry." >&2
                exit 1
            fi
            if ! registry_cli hooks-doctor --quiet; then
                echo "Warning: Shuttle's Codex hooks are missing, differ, or are untrusted." >&2
                echo "  Resuming in degraded mode; run 'shuttle hooks doctor'." >&2
                registry_cli degrade "$LAUNCH_ID" "Codex hooks missing, different, or untrusted" || true
            fi
            CODEX_COMMAND=(codex resume "$SESSION_ID")
            [ -z "$PROMPT" ] || CODEX_COMMAND+=("$PROMPT")
            SUPERVISOR=(env "PYTHONPATH=$SHUTTLE_ROOT${PYTHONPATH:+:$PYTHONPATH}" python3 -m shuttlelib.supervisor --launch-id "$LAUNCH_ID" --tmux-session "$TMUX_SESSION" -- "${CODEX_COMMAND[@]}")
            printf -v RESUME_COMMAND '%q ' "${SUPERVISOR[@]}"
            run_tmux_new_session "$TMUX_SESSION" "$PROJECT_DIR" "$RESUME_COMMAND"
            if [ "$TMUX_NEW_SESSION_RC" -ne 0 ]; then
                close_launch_failed "$LAUNCH_ID" "$TMUX_NEW_SESSION_RC" "tmux failed to create session $TMUX_SESSION"
                exit "$TMUX_NEW_SESSION_RC"
            fi
        fi

        echo "Resuming $AGENT session $SESSION_ID"
        echo "  Project: $PROJECT_DIR"
        echo "  Tmux: $TMUX_SESSION"
        if [ -n "$HEADLESS" ] || [ -n "$SHUTTLE_HEADLESS" ] || [ -z "$DISPLAY" ]; then
            echo "Attach with: tmux attach -t $TMUX_SESSION"
        else
            launch_terminal "shuttle:$TMUX_SESSION" tmux attach -t "=$TMUX_SESSION"
            echo "Launched $TMUX_SESSION"
        fi
        ;;

    export|x)
        claude_only_args export "$@"
        set -- "${CLAUDE_ARGS[@]}"
        # Parse options
        OUTPUT_FORMAT="markdown"
        OUTPUT_FILE=""
        LAST_N=""
        POSITIONAL=()

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --json|-j)
                    OUTPUT_FORMAT="json"
                    shift
                    ;;
                --file|-f)
                    OUTPUT_FILE="$2"
                    shift 2
                    ;;
                --last|-l)
                    LAST_N="$2"
                    shift 2
                    ;;
                *)
                    POSITIONAL+=("$1")
                    shift
                    ;;
            esac
        done
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ]; then
            echo "Usage: shuttle export <n|session-id> [options]"
            echo "  Export a CC session to markdown or JSON"
            echo ""
            echo "Options:"
            echo "  --json, -j        Output as JSON instead of markdown"
            echo "  --file, -f FILE   Write to file instead of stdout"
            echo "  --last, -l N      Only include last N messages"
            echo ""
            echo "Examples:"
            echo "  shuttle export 1                    # export session 1 as markdown"
            echo "  shuttle export 1 --json             # export as JSON"
            echo "  shuttle export abc123-uuid --file out.md"
            echo "  shuttle export 1 --last 20          # last 20 messages only"
            exit 1
        fi

        TARGET="$1"
        CC_PROJECTS="$HOME/.claude/projects"

        # Determine if target is tmux session number/name or raw UUID
        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            # Numeric: treat as tmux session index
            SESSION=$(resolve_session "$TARGET") || exit $?
            # Get session's working directory
            CWD=$(session_cwd "$SESSION")
            if [ -z "$CWD" ]; then
                echo "Could not get session working directory"
                exit 1
            fi
            # Convert to CC project path
            PROJECT_PATH=$(echo "$CWD" | sed 's|^/||; s|/|-|g; s|^|-|')
            CC_PROJECT_DIR="$CC_PROJECTS/$PROJECT_PATH"
            if [ ! -d "$CC_PROJECT_DIR" ]; then
                echo "No CC history found for: $CWD"
                exit 1
            fi
            # Find most recent session file
            SESSION_FILE=$(ls -t "$CC_PROJECT_DIR"/*.jsonl 2>/dev/null | grep -v '/agent-' | head -1)
            SESSION_ID=$(basename "$SESSION_FILE" .jsonl)
        elif SESSION=$(tmux display-message -t "$TARGET" -p '#{session_name}' 2>/dev/null) \
            && [ -n "$SESSION" ]; then
            # Gate and lookup must agree. Ask tmux to resolve the name and hand back
            # the session it actually chose, then look THAT up.
            #
            # Not resolve_session: it matches by SUBSTRING, and export's next branch is
            # a Claude UUID. A partial UUID like 'deadbee' would be stolen by any live
            # session whose name merely contains it, exporting the wrong transcript.
            # tmux matches by PREFIX, which is the behaviour export always had.
            CWD=$(session_cwd "$SESSION")
            if [ -z "$CWD" ]; then
                echo "Could not get session working directory"
                exit 1
            fi
            PROJECT_PATH=$(echo "$CWD" | sed 's|^/||; s|/|-|g; s|^|-|')
            CC_PROJECT_DIR="$CC_PROJECTS/$PROJECT_PATH"
            if [ ! -d "$CC_PROJECT_DIR" ]; then
                echo "No CC history found for: $CWD"
                exit 1
            fi
            SESSION_FILE=$(ls -t "$CC_PROJECT_DIR"/*.jsonl 2>/dev/null | grep -v '/agent-' | head -1)
            SESSION_ID=$(basename "$SESSION_FILE" .jsonl)
        else
            # Treat as UUID - search for it
            SESSION_ID="$TARGET"
            SESSION_FILE=$(find "$CC_PROJECTS" -name "${SESSION_ID}.jsonl" -type f 2>/dev/null | head -1)
            if [ -z "$SESSION_FILE" ]; then
                # Try partial match
                SESSION_FILE=$(find "$CC_PROJECTS" -name "*.jsonl" -type f 2>/dev/null | grep "$SESSION_ID" | head -1)
            fi
        fi

        if [ -z "$SESSION_FILE" ] || [ ! -f "$SESSION_FILE" ]; then
            echo "Session file not found: $TARGET"
            echo "Use 'shuttle search' to find valid session IDs"
            exit 1
        fi

        # Extract metadata
        ENCODED_PATH=$(basename "$(dirname "$SESSION_FILE")")
        PROJECT=$(echo "$ENCODED_PATH" | sed 's/^-//; s/-/\//g')
        PROJECT="/$PROJECT"
        FILE_DATE=$(stat -c %Y "$SESSION_FILE" 2>/dev/null || stat -f %m "$SESSION_FILE" 2>/dev/null || echo 0)
        DATE_STR=$(date -d "@$FILE_DATE" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || date -r "$FILE_DATE" "+%Y-%m-%d %H:%M:%S")

        # Read messages (optionally limited)
        # Note: --last N means "last N messages" not "last N JSONL lines"
        # CC session files have mixed record types (user, assistant, summary, etc.)
        # We filter to user/assistant first, THEN limit to last N
        if [ -n "$LAST_N" ]; then
            MESSAGES=$(jq -c 'select(.type == "user" or .type == "assistant")' "$SESSION_FILE" | tail -n "$LAST_N")
        else
            MESSAGES=$(cat "$SESSION_FILE")
        fi

        # Generate output
        if [ "$OUTPUT_FORMAT" = "json" ]; then
            # JSON output: array of cleaned message objects
            OUTPUT=$(echo "$MESSAGES" | jq -s --arg session "$SESSION_ID" --arg project "$PROJECT" --arg date "$DATE_STR" '
                {
                    session_id: $session,
                    project: $project,
                    date: $date,
                    messages: [
                        .[] |
                        select(.type == "user" or .type == "assistant") |
                        {
                            role: .message.role,
                            content: (
                                if .message.content | type == "string" then
                                    .message.content
                                elif .message.content | type == "array" then
                                    [.message.content[] | select(.type == "text") | .text] | join("\n")
                                else
                                    ""
                                end
                            )
                        } |
                        select(.content != "" and .content != null)
                    ]
                }
            ' 2>/dev/null)
        else
            # Markdown output
            OUTPUT="# Session: $SESSION_ID

Project: $PROJECT
Date: $DATE_STR

---
"
            # Process each message
            while IFS= read -r line; do
                TYPE=$(echo "$line" | jq -r '.type // "unknown"' 2>/dev/null)
                ROLE=$(echo "$line" | jq -r '.message.role // ""' 2>/dev/null)

                if [ "$TYPE" = "user" ] && [ "$ROLE" = "user" ]; then
                    CONTENT=$(echo "$line" | jq -r '
                        .message.content |
                        if type == "string" then .
                        elif type == "array" then
                            [.[] | select(.type == "text") | .text] | join("\n")
                        else ""
                        end
                    ' 2>/dev/null)
                    if [ -n "$CONTENT" ] && [ "$CONTENT" != "null" ]; then
                        OUTPUT+="
## User

$CONTENT

"
                    fi
                elif [ "$TYPE" = "assistant" ] && [ "$ROLE" = "assistant" ]; then
                    CONTENT=$(echo "$line" | jq -r '
                        [.message.content[] | select(.type == "text") | .text] | join("\n")
                    ' 2>/dev/null)
                    if [ -n "$CONTENT" ] && [ "$CONTENT" != "null" ]; then
                        OUTPUT+="
## Claude

$CONTENT

"
                    fi
                fi
            done <<< "$MESSAGES"
        fi

        # Output to file or stdout
        if [ -n "$OUTPUT_FILE" ]; then
            echo "$OUTPUT" > "$OUTPUT_FILE"
            echo "Exported to: $OUTPUT_FILE"
            if [ "$OUTPUT_FORMAT" = "json" ]; then
                MSG_COUNT=$(echo "$OUTPUT" | jq '.messages | length' 2>/dev/null || echo "?")
            else
                MSG_COUNT=$(echo "$OUTPUT" | grep -c "^## " || echo "?")
            fi
            echo "  Session: $SESSION_ID"
            echo "  Messages: $MSG_COUNT"
        else
            echo "$OUTPUT"
        fi
        ;;

    peek|p)
        AGENT=""
        POSITIONAL=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --agent) AGENT="$2"; validate_agent "$AGENT"; shift 2 ;;
                *) POSITIONAL+=("$1"); shift ;;
            esac
        done
        TARGET="${POSITIONAL[0]:-1}"
        LINES="${POSITIONAL[1]:-20}"
        SESSION=$(resolve_session "$TARGET" "$AGENT") || exit $?

        echo "=== $SESSION (last $LINES lines) ==="
        PEEK_PANE=$(session_pane "$SESSION")
        if [ -z "$PEEK_PANE" ]; then
            echo "No live pane found for '$SESSION'." >&2
            exit 1
        fi
        tmux capture-pane -t "$PEEK_PANE" -p | tail -n "$LINES"
        ;;

    tail|t)
        TARGET="${1:-1}"
        INTERVAL="${2:-1}"

        # One funnel for human target -> tmux session, same as peek/send/relay:
        # exact name wins, a partial must identify exactly one session, ambiguity is
        # an error. The old `tmux ls | grep "$TARGET" | head -1` took a substring's
        # FIRST hit with no ambiguity check, so `tail auth` could stream `a-auth`
        # even when a session named exactly `auth` was live.
        SESSION=$(resolve_session "$TARGET") || exit $?

        # Bind the pane id once, up front. Re-resolving a bare session name every
        # tick would let tmux slide from exact match to prefix match the moment
        # this session exits, and silently stream a DIFFERENT session's output
        # under this session's header.
        TAIL_PANE=$(session_pane "$SESSION")
        if [ -z "$TAIL_PANE" ]; then
            echo "No live pane found for '$SESSION'." >&2
            exit 1
        fi

        echo "=== Tailing $SESSION (Ctrl-C to exit) ==="

        # We track content by keeping a hash of the last capture
        # and only showing new lines when content changes
        LAST_HASH=""
        LAST_LINE_COUNT=0

        # Capture full pane including scrollback (-S - starts from beginning)
        # Use temporary file to handle multi-line content properly
        CAPTURE_FILE=$(mktemp)
        trap "rm -f $CAPTURE_FILE" EXIT

        while true; do
            # Capture current pane content (full scrollback)
            if ! tmux capture-pane -t "$TAIL_PANE" -p -S - > "$CAPTURE_FILE" 2>/dev/null; then
                echo "=== Session $SESSION ended ==="
                exit 0
            fi

            # Get current line count
            CURRENT_LINE_COUNT=$(wc -l < "$CAPTURE_FILE")

            # Get hash of content to detect changes
            CURRENT_HASH=$(md5sum "$CAPTURE_FILE" | cut -d' ' -f1)

            if [ "$CURRENT_HASH" != "$LAST_HASH" ]; then
                # Content changed - show new lines
                if [ "$LAST_LINE_COUNT" -gt 0 ]; then
                    # Show only lines after what we've already seen
                    NEW_LINES=$((CURRENT_LINE_COUNT - LAST_LINE_COUNT))
                    if [ "$NEW_LINES" -gt 0 ]; then
                        tail -n "$NEW_LINES" "$CAPTURE_FILE"
                    elif [ "$NEW_LINES" -lt 0 ]; then
                        # Screen was cleared or scrollback reduced - show recent context
                        echo "--- (screen cleared) ---"
                        tail -n 5 "$CAPTURE_FILE"
                    fi
                else
                    # First capture - show last 10 lines for context
                    tail -n 10 "$CAPTURE_FILE"
                fi

                LAST_HASH="$CURRENT_HASH"
                LAST_LINE_COUNT="$CURRENT_LINE_COUNT"
            fi

            sleep "$INTERVAL"
        done
        ;;

    go|g)
        # Handle --help before parsing other options
        for arg in "$@"; do
            if [ "$arg" = "--help" ] || [ "$arg" = "-h" ]; then
                echo "Usage: shuttle go [options] <brief-id>"
                echo ""
                echo "Launch a new Claude or Codex session on a SKEIN brief."
                echo ""
                echo "Options:"
                echo "  -d, --dir PATH      Run in specified directory"
                echo "  -p, --project NAME  Run in ~/projects/NAME"
                echo "  --headless          Don't open GUI terminal"
                echo "  --agent NAME        claude (default) or codex"
                echo "  -h, --help          Show this help"
                echo ""
                echo "Examples:"
                echo "  shuttle go brief-20251210-ceor"
                echo "  shuttle go -p skein brief-20251210-ceor"
                echo "  shuttle go --headless brief-id"
                exit 0
            fi
        done

        parse_project_opts "$@"
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ]; then
            echo "Usage: shuttle go [--agent claude|codex] [--dir PATH | --project NAME] <brief-id>"
            exit 1
        fi
        BRIEF_ID="$1"

        # Check if brief exists and extract title for session name. See
        # resolve_brief_owner for how the owning project is found regardless
        # of the invoking cwd.
        resolve_brief_owner "$BRIEF_ID"
        BRIEF_TITLE=$(brief_title_slug "$BRIEF_RENDER")

        # -d explicit tolerates a brief SKEIN doesn't know about: the user pinned a
        # directory, so fall through and launch there with the raw id as the title.
        if [ -z "$BRIEF_FOUND" ] && [ -z "$EXPLICIT_DIR" ]; then
            echo "Brief not found: $BRIEF_ID"
            echo "Not found in current project or any registered SKEIN project."
            if [ -n "$BRIEF_RENDER" ]; then
                echo "$BRIEF_RENDER"
            fi
            exit 1
        fi

        # BRIEF_ID is raw user input; it must never become a session name as-is.
        SESSION="shuttle-$(safe_session_name "${BRIEF_TITLE:-$BRIEF_ID}")"

        if [ "$AGENT" = "codex" ]; then
            SESSION="shuttle-codex-${SESSION#shuttle-}"
        fi

        # Check if session already exists - reboard instead of creating new
        if tmux has-session -t "=$SESSION" 2>/dev/null; then
            echo "Session '$SESSION' exists - reboarding..."
            if [ -n "$HEADLESS" ]; then
                echo "Attach with: tmux attach -t $SESSION"
            else
                launch_terminal "shuttle:$SESSION" tmux attach -t "=$SESSION"
            fi
            exit 0
        fi

        echo "Launching: $SESSION [$AGENT] (in $PROJECT_DIR)"

        PROVIDER_VERSION=$($AGENT --version 2>/dev/null | head -1 | awk '{print $NF}' || true)
        # '=' form: a value can never be mistaken for a flag, whatever the title slugs to.
        CREATE_ARGS=(create "--provider=$AGENT" "--provider-version=${PROVIDER_VERSION:-unknown}" --mode=go "--cwd=$PROJECT_DIR" "--tmux-session=$SESSION" "--brief=$BRIEF_ID" "--title=${BRIEF_TITLE:-$BRIEF_ID}")
        if ! LAUNCH_ID=$(registry_cli "${CREATE_ARGS[@]}"); then
            echo "Error: could not register the launch in the Shuttle session registry." >&2
            exit 1
        fi

        if [ "$AGENT" = "codex" ] && ! registry_cli hooks-doctor --quiet; then
            echo "Warning: Shuttle's Codex hooks are missing, differ, or are untrusted." >&2
            echo "  Launching in degraded mode; run 'shuttle hooks doctor' for exact read-only diagnostics." >&2
            registry_cli degrade "$LAUNCH_ID" "Codex hooks missing, different, or untrusted" || true
        fi

        PROVIDER_COMMAND=("$AGENT")
        if [ "$AGENT" = "codex" ]; then
            PROVIDER_COMMAND+=("HANDOFF: $BRIEF_ID")
        fi
        SUPERVISOR=(env "PYTHONPATH=$SHUTTLE_ROOT${PYTHONPATH:+:$PYTHONPATH}" python3 -m shuttlelib.supervisor --launch-id "$LAUNCH_ID" --tmux-session "$SESSION" -- "${PROVIDER_COMMAND[@]}")
        printf -v SUPERVISOR_COMMAND '%q ' "${SUPERVISOR[@]}"
        run_tmux_new_session "$SESSION" "$PROJECT_DIR" "$SUPERVISOR_COMMAND"
        if [ "$TMUX_NEW_SESSION_RC" -ne 0 ]; then
            close_launch_failed "$LAUNCH_ID" "$TMUX_NEW_SESSION_RC" "tmux failed to create session $SESSION"
            exit "$TMUX_NEW_SESSION_RC"
        fi

        if [ "$AGENT" = "claude" ]; then
            # Preserve the established Claude launch path for this slice.
            echo "Waiting for Claude..."
            # No bare-name fallback: if the pane is gone the session died on startup,
            # and a bare name would prefix-match a NEIGHBOURING session, read its
            # prompt, and print a confident "Ready!" for a session that is dead.
            # An honest timeout beats a lying readiness signal.
            READY_PANE=$(session_pane "$SESSION")
            MAX_ITERATIONS=$((SHUTTLE_PROMPT_TIMEOUT * 5))
            for ((i=1; i<=MAX_ITERATIONS; i++)); do
                [ -n "$READY_PANE" ] || break
                # '|| true': a bare failing capture-pane would abort the launch under
                # `set -e` with no message, after the session and registry row exist.
                CAPTURED=$(tmux capture-pane -t "$READY_PANE" -p 2>/dev/null || true)
                if echo "$CAPTURED" | grep -qE "^>|? for"; then
                    echo "Ready!"
                    break
                fi
                sleep 0.2
            done
            echo "Waiting for input handler..."
            sleep 4
            tmux_send_cmd "$SESSION" "HANDOFF: $BRIEF_ID"
        fi

        # Open terminal or print attach instructions
        if [ -n "$HEADLESS" ]; then
            echo "Session ready: $SESSION"
            echo "Attach with: tmux attach -t $SESSION"
        else
            launch_terminal "shuttle:$SESSION" tmux attach -t "=$SESSION"
            echo "Launched $SESSION"
        fi
        ;;

    split|s|vsplit|vs)
        # Determine split direction
        if [[ "$CMD" == "vsplit" || "$CMD" == "vs" ]]; then
            SPLIT_FLAG="-v"
            SPLIT_TYPE="vertical"
        else
            SPLIT_FLAG="-h"
            SPLIT_TYPE="horizontal"
        fi

        parse_project_opts "$@"
        set -- "${POSITIONAL[@]}"
        if [ "$AGENT" != "claude" ]; then
            echo "Error: shuttle $CMD is Claude-only in this release"
            exit 1
        fi

        if [ -z "$1" ]; then
            echo "Usage: shuttle $CMD [--dir PATH | --project NAME] <brief-id>"
            exit 1
        fi

        if [ -z "$TMUX" ]; then
            echo "Error: $CMD requires being inside a tmux session"
            echo "Use 'shuttle go <brief>' to launch in a new window instead"
            exit 1
        fi

        BRIEF_ID="$1"

        # Cross-project resolution (same logic as 'go' — see resolve_brief_owner)
        BRIEF_FOUND=""
        if [ -z "$EXPLICIT_DIR" ]; then
            resolve_brief_owner "$BRIEF_ID"

            if [ -z "$BRIEF_FOUND" ]; then
                echo "Brief not found: $BRIEF_ID"
                echo "Not found in current project or any registered SKEIN project."
                if [ -n "$BRIEF_RENDER" ]; then
                    echo "$BRIEF_RENDER"
                fi
                exit 1
            fi
        fi

        echo "Opening $SPLIT_TYPE split for $BRIEF_ID (in $PROJECT_DIR)..."

        # Create split running claude, capture the new pane ID
        NEW_PANE=$(tmux split-window $SPLIT_FLAG -c "$PROJECT_DIR" -P -F '#{pane_id}' "claude")

        # Wait for claude prompt in the NEW pane (timeout based on config)
        echo "Waiting for Claude..."
        MAX_ITERATIONS=$((SHUTTLE_PROMPT_TIMEOUT * 5))  # 5 checks per second
        for ((i=1; i<=MAX_ITERATIONS; i++)); do
            # '|| true': if claude dies on startup tmux destroys the pane and a bare
            # capture-pane exits nonzero, which would abort the whole command under
            # `set -e` with only tmux's raw "can't find pane" and no explanation.
            # Same guard `go`'s readiness loop already carries.
            CAPTURED=$(tmux capture-pane -t "$NEW_PANE" -p 2>/dev/null || true)
            # Look for Claude's prompt or shortcuts hint
            if echo "$CAPTURED" | grep -qE "^>|? for"; then
                break
            fi
            sleep 0.2
        done

        # Wait for CC input handler to fully initialize after prompt appears
        echo "Waiting for input handler..."
        sleep 4

        # Send the HANDOFF to the specific pane we created
        # NEW_PANE is a real pane id, straight from split-window -P -F '#{pane_id}'.
        tmux_send_pane "$NEW_PANE" "HANDOFF: $BRIEF_ID"
        echo "Split opened. Use 'shuttle unsplit' to close."
        ;;

    unsplit)
        if [ -z "$TMUX" ]; then
            echo "Error: unsplit requires being inside a tmux session"
            exit 1
        fi

        PANE_COUNT=$(tmux list-panes | wc -l)
        if [ "$PANE_COUNT" -eq 1 ]; then
            echo "No split pane to close"
            exit 0
        fi

        # Kill the other pane (not the current one)
        CURRENT_PANE=$(tmux display-message -p '#{pane_index}')
        if [ "$CURRENT_PANE" -eq 0 ]; then
            tmux kill-pane -t 1
        else
            tmux kill-pane -t 0
        fi
        echo "Split closed."
        ;;

    watch|w)
        while true; do
            clear
            "$0" status
            sleep 2
        done
        ;;

    ground)
        tmux ls 2>/dev/null | grep "^shuttle-" | cut -d: -f1 | while IFS= read -r sess; do
            echo "  Killing $sess"
            # '=' is mandatory here. A bare name prefix-matches, so if this session
            # exits between the listing and the kill, tmux would happily kill a
            # NEIGHBOUR whose name starts with it (shuttle-foo -> shuttle-foo-long).
            # '|| true' so one already-dead session doesn't abort the sweep.
            tmux kill-session -t "=$sess" || true
        done
        echo "Done."
        ;;

    hook)
        if [ "$1" != "codex" ] || [ -n "$2" ]; then
            echo "Usage: shuttle hook codex" >&2
            exit 1
        fi
        exec env "PYTHONPATH=$SHUTTLE_ROOT${PYTHONPATH:+:$PYTHONPATH}" python3 -m shuttlelib.codex_hook
        ;;

    hooks|codex-hooks)
        HOOK_ACTION="${1:-snippet}"
        case "$HOOK_ACTION" in
            snippet|show)
                echo "Shuttle Codex hook fragment for additive merge into CODEX_HOME/hooks.json or ~/.codex/hooks.json (not a replacement):"
                registry_cli hooks-snippet
                ;;
            install)
                registry_cli hooks-install
                ;;
            doctor|check)
                echo "Shuttle Codex hook fragment for additive merge into CODEX_HOME/hooks.json or ~/.codex/hooks.json (not a replacement):"
                registry_cli hooks-snippet
                echo ""
                if registry_cli hooks-doctor; then
                    :
                else
                    echo "Hooks are not ready. Codex launches will continue in degraded mode."
                    exit 1
                fi
                ;;
            *)
                echo "Usage: shuttle hooks [snippet|doctor|install]"
                exit 1
                ;;
        esac
        ;;

    config|cfg)
        echo "SHUTTLE CONFIGURATION"
        echo ""
        if [ -n "$SHUTTLE_LOADED_CONFIG" ]; then
            echo "Config file: $SHUTTLE_LOADED_CONFIG"
        else
            echo "Config file: (none found)"
            echo "  Checked locations:"
            for path in "${SHUTTLE_CONFIG_PATHS[@]}"; do
                echo "    - $path"
            done
        fi
        echo ""
        echo "Current settings:"
        echo "  SHUTTLE_DEFAULT_PROJECT = ${SHUTTLE_DEFAULT_PROJECT:-(not set, uses pwd)}"
        echo "  SHUTTLE_DEFAULT_SITE    = $SHUTTLE_DEFAULT_SITE"
        echo "  SHUTTLE_DEFAULT_AGENT   = $SHUTTLE_DEFAULT_AGENT"
        echo "  SHUTTLE_HEADLESS_DEFAULT= ${SHUTTLE_HEADLESS_DEFAULT:-(auto-detect)}"
        echo "  SHUTTLE_PROMPT_TIMEOUT  = ${SHUTTLE_PROMPT_TIMEOUT}s"
        echo "  Terminal                = gnome-terminal (hardcoded; xterm emergency fallback)"
        echo ""
        echo "Environment overrides (set these to override config):"
        echo "  SHUTTLE_PROJECT  = ${SHUTTLE_PROJECT:-}"
        echo "  SHUTTLE_SITE     = ${SHUTTLE_SITE:-}"
        echo "  SHUTTLE_DEFAULT_AGENT = ${ENV_SHUTTLE_DEFAULT_AGENT:-}"
        echo "  SHUTTLE_HEADLESS = ${SHUTTLE_HEADLESS:-}"
        echo "  SHUTTLE_TIMEOUT  = ${SHUTTLE_TIMEOUT:-}"
        echo ""
        echo "Example config file (~/.config/shuttle/config or ~/.shuttlerc):"
        cat << 'EXAMPLE'
# Shuttle configuration

# Default project directory (empty = use pwd)
SHUTTLE_DEFAULT_PROJECT=~/projects/main

# Default SKEIN site for briefs
SHUTTLE_DEFAULT_SITE=ledger

# Default provider: claude or codex
SHUTTLE_DEFAULT_AGENT=claude

# Always run headless (set to 1, or leave empty for auto-detect)
SHUTTLE_HEADLESS_DEFAULT=

# Prompt detection timeout in seconds
SHUTTLE_PROMPT_TIMEOUT=12
EXAMPLE
        ;;

    doctor|dr)
        echo "SHUTTLE DOCTOR — gnome-terminal launch diagnostics"
        echo ""

        echo "Display"
        echo "  DISPLAY          = ${DISPLAY:-(unset — headless)}"
        echo "  WAYLAND_DISPLAY  = ${WAYLAND_DISPLAY:-(unset)}"
        echo "  XDG_SESSION_TYPE = ${XDG_SESSION_TYPE:-(unset)}"
        echo ""

        echo "Inherited gnome-terminal env (stripped before each launch)"
        if [ -n "$GNOME_TERMINAL_SCREEN" ]; then
            echo "  GNOME_TERMINAL_SCREEN  = $GNOME_TERMINAL_SCREEN"
            echo "    -> inherited from a parent gnome-terminal. If that window is closed,"
            echo "       the path is dead and any bare 'gnome-terminal' call in this shell"
            echo "       will fail. Shuttle strips this var before launching."
        else
            echo "  GNOME_TERMINAL_SCREEN  = (unset — clean)"
        fi
        if [ -n "$GNOME_TERMINAL_SERVICE" ]; then
            echo "  GNOME_TERMINAL_SERVICE = $GNOME_TERMINAL_SERVICE"
        else
            echo "  GNOME_TERMINAL_SERVICE = (unset — clean)"
        fi
        echo ""

        if registry_cli hooks-doctor; then
            :
        else
            echo "  Codex launches remain available in degraded mode."
        fi
        echo ""

        echo "gnome-terminal"
        if command -v gnome-terminal >/dev/null 2>&1; then
            echo "  binary           = $(command -v gnome-terminal)"
            GT_VERSION=$(gnome-terminal --version 2>&1 | head -1)
            echo "  version          = ${GT_VERSION:-(unknown)}"
        else
            echo "  binary           = NOT FOUND"
        fi
        GT_SERVER=$(pgrep -fa gnome-terminal-server | head -1)
        if [ -n "$GT_SERVER" ]; then
            echo "  server pid       = $(echo "$GT_SERVER" | awk '{print $1}')"
        else
            echo "  server pid       = (not running — will spawn on first launch)"
        fi
        echo ""

        echo "Fallback / verification tools"
        for tool in xterm wmctrl xdotool dbus-launch; do
            if command -v "$tool" >/dev/null 2>&1; then
                echo "  $tool $(printf '%*s' $((14 - ${#tool})) '')= $(command -v "$tool")"
            else
                echo "  $tool $(printf '%*s' $((14 - ${#tool})) '')= (missing)"
            fi
        done
        echo ""

        echo "Smoke test: gnome-terminal --wait -- bash -c 'exit 0' (with stale env stripped)"
        if [ -z "$DISPLAY" ] && [ -z "$WAYLAND_DISPLAY" ]; then
            echo "  SKIPPED — no display available (headless box)"
        elif ! command -v gnome-terminal >/dev/null 2>&1; then
            echo "  SKIPPED — gnome-terminal not installed"
        else
            SMOKE_ERR=$(mktemp /tmp/shuttle-doctor-XXXXXX)
            SMOKE_TITLE="shuttle-doctor-$$"
            set +e
            timeout 5 env -u GNOME_TERMINAL_SCREEN -u GNOME_TERMINAL_SERVICE \
                gnome-terminal --title "$SMOKE_TITLE" --wait -- bash -c 'exit 0' 2>"$SMOKE_ERR"
            SMOKE_RC=$?
            set -e
            SMOKE_STDERR=$(cat "$SMOKE_ERR")
            rm -f "$SMOKE_ERR"
            if [ "$SMOKE_RC" -eq 0 ] && [ -z "$SMOKE_STDERR" ]; then
                echo "  PASS — gnome-terminal opened and exited cleanly"
            elif [ "$SMOKE_RC" -eq 0 ]; then
                echo "  PASS (with stderr noise — usually harmless GTK warnings):"
                echo "$SMOKE_STDERR" | sed 's/^/    /'
            else
                echo "  FAIL — exit $SMOKE_RC"
                if [ -n "$SMOKE_STDERR" ]; then
                    echo "$SMOKE_STDERR" | sed 's/^/    /'
                fi
                if terminal_errors_are_dbus_stale "$SMOKE_STDERR"; then
                    echo ""
                    echo "  Diagnosis: stale env was stripped but gnome-terminal still failed."
                    echo "  This points at a genuinely sick gnome-terminal-server, not just"
                    echo "  a leaked GNOME_TERMINAL_SCREEN. Recovery (kills other shuttle"
                    echo "  windows — tmux sessions survive):"
                    echo "    killall gnome-terminal-server"
                fi
            fi
        fi
        ;;

    index|i)
        claude_only_args index "$@"
        set -- "${CLAUDE_ARGS[@]}"
        # Index all CC sessions for fast search
        SHUTTLE_INDEX_DIR="$HOME/.shuttle"
        SHUTTLE_INDEX_FILE="$SHUTTLE_INDEX_DIR/index.json"
        CC_PROJECTS="$HOME/.claude/projects"

        # Parse options
        UPDATE_MODE=""
        VERBOSE=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --update|-u)
                    UPDATE_MODE=1
                    shift
                    ;;
                --verbose|-v)
                    VERBOSE=1
                    shift
                    ;;
                *)
                    echo "Unknown option: $1"
                    echo "Usage: shuttle index [--update] [--verbose]"
                    exit 1
                    ;;
            esac
        done

        # Create index directory (fail early if not possible)
        if ! mkdir -p "$SHUTTLE_INDEX_DIR" 2>/dev/null; then
            echo "Error: Cannot create index directory $SHUTTLE_INDEX_DIR"
            exit 1
        fi

        # Cross-platform stat for mtime (GNU vs BSD/macOS)
        get_mtime() {
            stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null || echo 0
        }

        # Load existing index for incremental updates using associative arrays (O(1) lookup)
        declare -A MTIME_CACHE
        declare -A ENTRIES_CACHE
        if [ -n "$UPDATE_MODE" ] && [ -f "$SHUTTLE_INDEX_FILE" ]; then
            # Validate index before loading
            if ! jq -e '.version and .sessions' "$SHUTTLE_INDEX_FILE" >/dev/null 2>&1; then
                echo "Warning: Index file is corrupted or invalid, performing full rebuild"
                UPDATE_MODE=""
            else
                echo "Incremental update mode - loading cache..."
                # Load mtimes and entries into associative arrays for O(1) lookup
                while IFS=$'\t' read -r key mtime; do
                    MTIME_CACHE["$key"]="$mtime"
                done < <(jq -r '.sessions | to_entries[] | "\(.key)\t\(.value.mtime)"' "$SHUTTLE_INDEX_FILE" 2>/dev/null)
                while IFS=$'\t' read -r key entry; do
                    ENTRIES_CACHE["$key"]="$entry"
                done < <(jq -r '.sessions | to_entries[] | "\(.key)\t\(.value | @json)"' "$SHUTTLE_INDEX_FILE" 2>/dev/null)
                echo "  Loaded ${#MTIME_CACHE[@]} cached entries"
            fi
        fi
        if [ -z "$UPDATE_MODE" ]; then
            echo "Full index rebuild"
        fi

        # Count files for progress (consistent with null-delimited processing)
        TOTAL_FILES=$(find "$CC_PROJECTS" -name "*.jsonl" -type f -print0 2>/dev/null | grep -zc -v '/agent-' || echo 0)
        echo "Found $TOTAL_FILES session files to process"

        # Process each session file
        PROCESSED=0
        SKIPPED=0
        UPDATED=0

        # Create temp file for building index (in same dir for atomic mv)
        INDEX_TMP=$(mktemp -p "$SHUTTLE_INDEX_DIR" 2>/dev/null || mktemp)
        INDEX_TMP_FORMATTED=""
        trap 'rm -f "$INDEX_TMP" "$INDEX_TMP_FORMATTED"' EXIT

        # Start JSON structure
        # Cross-platform ISO 8601 date
        LAST_UPDATED=$(date -Is 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S%z')
        echo '{"version":1,"last_updated":"'"$LAST_UPDATED"'","sessions":{' > "$INDEX_TMP"
        FIRST_ENTRY=1

        # Track seen session IDs to prevent duplicates (invalid JSON)
        declare -A SEEN_IDS

        # Use process substitution with null delimiter for filenames with special chars
        while IFS= read -r -d '' FILE; do
            # Skip empty files first (before any expensive operations)
            if [ ! -s "$FILE" ]; then
                continue
            fi

            SESSION_ID=$(basename "$FILE" .jsonl)

            # Skip duplicate session IDs (would produce invalid JSON)
            if [ -n "${SEEN_IDS[$SESSION_ID]:-}" ]; then
                [ -n "$VERBOSE" ] && echo "  Warning: Duplicate session ID $SESSION_ID, skipping"
                continue
            fi
            SEEN_IDS[$SESSION_ID]=1

            # Get file mtime using cross-platform function
            FILE_MTIME=$(get_mtime "$FILE")

            # In update mode, check if file changed (O(1) associative array lookup)
            if [ -n "$UPDATE_MODE" ] && [ ${#MTIME_CACHE[@]} -gt 0 ]; then
                INDEXED_MTIME="${MTIME_CACHE[$SESSION_ID]:-}"
                if [ -n "$INDEXED_MTIME" ] && [ "$FILE_MTIME" = "$INDEXED_MTIME" ]; then
                    # File unchanged, copy existing entry from cache
                    EXISTING_ENTRY="${ENTRIES_CACHE[$SESSION_ID]:-}"
                    if [ -n "$EXISTING_ENTRY" ]; then
                        if [ "$FIRST_ENTRY" -eq 0 ]; then
                            echo "," >> "$INDEX_TMP"
                        fi
                        # Use jq escaping for IDs with special chars (quotes, backslashes, shell metachars, control)
                        # Fast path for clean UUIDs (99.99% of cases)
                        if [[ "$SESSION_ID" =~ [\"\\\$\`[:cntrl:]] ]]; then
                            ESCAPED_ID=$(printf '%s' "$SESSION_ID" | jq -Rs '.')
                        else
                            ESCAPED_ID="\"$SESSION_ID\""
                        fi
                        printf '%s:%s\n' "$ESCAPED_ID" "$EXISTING_ENTRY" >> "$INDEX_TMP"
                        FIRST_ENTRY=0
                        ((SKIPPED++)) || true
                        continue
                    fi
                fi
            fi

            # Decode project path from directory name
            ENCODED_PATH=$(basename "$(dirname "$FILE")")
            PROJECT=$(echo "$ENCODED_PATH" | sed 's/^-//; s/-/\//g')
            PROJECT="/$PROJECT"

            # Extract metadata from file
            # Get first timestamp and first user message
            FIRST_LINE=$(head -1 "$FILE")
            STARTED=$(echo "$FIRST_LINE" | jq -r '.timestamp // empty' 2>/dev/null)

            # Get first user message for summary
            FIRST_MSG=$(grep '"type":"user"' "$FILE" 2>/dev/null | head -1 | jq -r '
                .message.content |
                if type == "string" then .[0:150]
                elif type == "array" then
                    ([.[] | select(.type == "text") | .text] | join(" "))[0:150]
                else ""
                end
            ' 2>/dev/null)

            # Count messages (user + assistant entries)
            # Use -a to treat binary files as text, validate result is numeric
            MSG_COUNT=$(grep -caE '"type":"(user|assistant)"' "$FILE" 2>/dev/null | tr -d '[:space:]')
            # Ensure MSG_COUNT is numeric (grep on binary can return warnings)
            if ! [[ "$MSG_COUNT" =~ ^[0-9]+$ ]]; then
                MSG_COUNT=0
            fi

            # Get last activity (use last line's timestamp or file mtime)
            LAST_LINE=$(tail -1 "$FILE")
            LAST_ACTIVITY=$(echo "$LAST_LINE" | jq -r '.timestamp // empty' 2>/dev/null)
            if [ -z "$LAST_ACTIVITY" ]; then
                LAST_ACTIVITY=$(date -Is -d "@$FILE_MTIME" 2>/dev/null || date -r "$FILE_MTIME" '+%Y-%m-%dT%H:%M:%S%z')
            fi

            # Build session entry
            if [ "$FIRST_ENTRY" -eq 0 ]; then
                echo "," >> "$INDEX_TMP"
            fi

            # Build JSON entry using jq for proper escaping, output as key:value
            ENTRY_JSON=$(jq -n -c \
                  --arg project "$PROJECT" \
                  --arg file "$FILE" \
                  --arg started "$STARTED" \
                  --arg last "$LAST_ACTIVITY" \
                  --argjson count "$MSG_COUNT" \
                  --arg summary "$FIRST_MSG" \
                  --argjson mtime "$FILE_MTIME" \
                '{project:$project,file:$file,started:$started,last_activity:$last,message_count:$count,summary:$summary,mtime:$mtime}')
            # Use jq escaping for IDs with special chars (same as SKIPPED path)
            if [[ "$SESSION_ID" =~ [\"\\\$\`[:cntrl:]] ]]; then
                ESCAPED_ID=$(printf '%s' "$SESSION_ID" | jq -Rs '.')
            else
                ESCAPED_ID="\"$SESSION_ID\""
            fi
            printf '%s:%s\n' "$ESCAPED_ID" "$ENTRY_JSON" >> "$INDEX_TMP"
            FIRST_ENTRY=0
            ((UPDATED++)) || true

            # Progress indicator
            ((PROCESSED++)) || true
            if [ -n "$VERBOSE" ]; then
                echo "  [$PROCESSED/$TOTAL_FILES] $SESSION_ID"
            elif [ $((PROCESSED % 100)) -eq 0 ]; then
                echo "  Processed $PROCESSED/$TOTAL_FILES..."
            fi
        done < <(find "$CC_PROJECTS" -name "*.jsonl" -type f -print0 2>/dev/null | grep -z -v '/agent-' || true)

        # Close JSON structure
        echo '}' >> "$INDEX_TMP"
        echo '}' >> "$INDEX_TMP"

        # Validate and format JSON, then atomic rename
        INDEX_TMP_FORMATTED=$(mktemp -p "$SHUTTLE_INDEX_DIR" 2>/dev/null || mktemp)
        if jq '.' "$INDEX_TMP" > "$INDEX_TMP_FORMATTED" 2>/dev/null; then
            # Atomic write: mv is atomic on same filesystem
            mv "$INDEX_TMP_FORMATTED" "$SHUTTLE_INDEX_FILE"
            SESSION_COUNT=$(jq '.sessions | length' "$SHUTTLE_INDEX_FILE")
            echo ""
            echo "Index complete: $SESSION_COUNT sessions"
            if [ -n "$UPDATE_MODE" ]; then
                echo "  Updated: $UPDATED, Skipped (unchanged): $SKIPPED"
            fi
            echo "Saved to: $SHUTTLE_INDEX_FILE"
        else
            rm -f "$INDEX_TMP_FORMATTED"
            echo "Error: Failed to create valid JSON index"
            cat "$INDEX_TMP"
            exit 1
        fi
        ;;

    whoami)
        # Generate and print a unique probe string for session identification
        # This allows agents to discover their own session ID by:
        # 1. Running `shuttle whoami` to get a unique probe
        # 2. Running `shuttle confirm <probe>` from outside to find the session
        PROBE="SESSION_PROBE_$(head -c 12 /dev/urandom | base64 | tr -d '/+=' | head -c 16)"
        echo "$PROBE"
        ;;

    confirm)
        # Find which CC session contains the probe string
        # Returns the session ID if found
        if [ -z "$1" ]; then
            echo "Usage: shuttle confirm <probe-string>"
            echo "  Find which CC session contains the probe (from 'shuttle whoami')"
            exit 1
        fi

        PROBE="$1"
        CC_PROJECTS="$HOME/.claude/projects"

        # Validate probe format (should start with SESSION_PROBE_)
        if [[ ! "$PROBE" =~ ^SESSION_PROBE_ ]]; then
            echo "Warning: Probe doesn't match expected format (SESSION_PROBE_*)"
        fi

        # Search all session files for the probe, excluding agent files
        MATCH_FILE=$(grep -r -l "$PROBE" "$CC_PROJECTS" 2>/dev/null | grep '\.jsonl$' | grep -v '/agent-' | head -1)

        if [ -z "$MATCH_FILE" ]; then
            echo "Probe not found in any session"
            exit 1
        fi

        # Extract session ID from filename
        SESSION_ID=$(basename "$MATCH_FILE" .jsonl)
        echo "$SESSION_ID"
        ;;

    score-sessions|score)
        # Score and rank CC sessions by signal density
        # Delegates to Python module for analysis
        SCORE_SCRIPT="$SCRIPT_DIR/../parser/score_sessions.py"
        if [ ! -f "$SCORE_SCRIPT" ]; then
            echo "Error: score_sessions.py not found at $SCORE_SCRIPT"
            exit 1
        fi
        exec python3 "$SCORE_SCRIPT" "$@"
        ;;

    help|--help|-h)
        cat << 'EOF'
shuttle - Manage Claude and Codex agent sessions

Commands:
  status          Show sessions, briefs, and shards (default)
  watch, w        Continuous status refresh (Ctrl-C to exit)
  ls              List active sessions
  board, b <n>    Board session by number or name
  kill, k <n>     Kill session by number or name
  peek, p <n> [lines]  Show last lines from session (default: 20)
  tail, t <n> [interval]  Live output stream from session (default: 1s refresh)
  context, ctx <n> [msgs]  Show conversation context (default: 10 messages)
  index, i        Build/update session index for fast search
  search <query>  Search CC session history (uses index)
  resume <id>     Resume a past CC session by UUID
  export, x <n|id>  Export session to markdown or JSON
  extract-pairs, ep  Extract training pairs from CC sessions
  send <n> <msg>  Send message to session (checks state first)
  relay <n> <file>  Send file contents to session (checks state, use '-' for stdin)
  whoami          Print unique probe string for session identification
  confirm <probe> Find session ID containing the probe string
  score-sessions  Score and rank sessions by signal density
  go, g <brief>   Launch new session on a brief
  split, s <brief>   Open brief in horizontal split pane
  vsplit, vs <brief> Open brief in vertical split pane
  unsplit         Close split pane
  ground          Kill all shuttle sessions
  config, cfg     Show current configuration
  doctor, dr      Diagnose gnome-terminal launch environment
  hooks [action]  Print, install, or diagnose additive Codex hooks
  hook codex      Codex hook stdin entry point (for hooks.json)

Index options:
  --update, -u    Incremental update (only changed files)
  --verbose, -v   Show progress for each file

Search options:
  --all, -a        Search all projects (default: current project)
  --list, -l       List sessions from index (no content search)
  --since, -s N    Only sessions from last N days
  --project, -p P  Filter by project path (substring match)
  --limit, -n N    Limit results (default: 20)

Send/relay options:
  --force, -f      Send even if session is not at prompt
  --wait, -w       Wait for session to reach prompt (up to 30s)

Targeting sessions:
  Most commands accept <number|name> for targeting sessions.

  <number>  Positional index from 'shuttle' output (e.g., 1, 2, 3)
            WARNING: These shift when sessions exit. Not safe for automation.

  <name>    Exact name, or a partial name that matches exactly one session
            (e.g., cc-speakbot-997451, shuttle-codex-my-task)
            Stable identifier that doesn't change. Recommended for watchman/automation.

  Race condition example:
    shuttle peek 3        # See session 3 needs approval
    # Session 2 exits here - numbers shift!
    shuttle send 3 "y"    # Now sends to WRONG session (was #4)

  Safe approach for automation:
    shuttle send cc-speakbot-997451 "y"   # Use full session name

Relay options:
  --no-enter, -n   Paste without pressing Enter

Options (for go, board, split, vsplit):
  -d, --dir PATH      Run in specified directory (go, split, vsplit)
  -p, --project NAME  Run in ~/projects/NAME (go, split, vsplit)
  --headless          Don't open GUI terminal (go, board)
  --agent NAME        Select claude or codex (bare go defaults to claude)
  (default: current directory or SHUTTLE_DEFAULT_PROJECT, auto-headless if no $DISPLAY)

Configuration:
  Config file: ~/.config/shuttle/config or ~/.shuttlerc
  See 'shuttle config' for current settings and example config.

  Environment variables (override config file):
    SHUTTLE_PROJECT   Default project directory
    SHUTTLE_SITE      Default SKEIN site for briefs
    SHUTTLE_DEFAULT_AGENT  Default provider: claude or codex
    SHUTTLE_HEADLESS  Force headless mode (1 = always headless)
    SHUTTLE_TIMEOUT   Prompt detection timeout in seconds
    SHUTTLE_SKIP_WINDOW_CHECK  Skip post-launch window verification (set to 1)

Export options:
  --json, -j        Output as JSON instead of markdown
  --file, -f FILE   Write to file instead of stdout
  --last, -l N      Only include last N messages

Extract-pairs options:
  --all, -a         Walk all CC sessions (~/.claude/projects/)
  --project, -p P   Filter sessions by project name
  --since, -s N     Only sessions from last N days
  --output, -o FILE Write JSONL to file (default: stdout)
  --min-context N   Min context turns before emitting pair (default: 1)
  --stats           Show statistics instead of JSONL output

Examples:
  shuttle                     # show status
  shuttle config              # show configuration
  shuttle index               # build full session index
  shuttle index --update      # incremental index update (~8s)
  shuttle search --list -a    # list all sessions from index
  shuttle search "auth" -a    # search content across all projects
  shuttle search -l -s 7      # list sessions from last 7 days
  shuttle go brief-20251210-ceor
  shuttle go --agent codex brief-20251210-ceor
  shuttle hooks install      # add Shuttle hooks without replacing other hooks
  shuttle hooks doctor       # print/check hooks; never edits dotfiles
  shuttle go -p skein brief-20251210-ceor  # launch in skein project
  shuttle go --headless brief-id  # create session without opening terminal
  shuttle split brief-20251210-ceor  # side-by-side pairing
  shuttle board 1             # board first session
  shuttle peek 1              # see what session 1 is doing
  shuttle peek 2 50           # last 50 lines from session 2
  shuttle tail 1              # live output from session 1
  shuttle tail 2 0.5          # faster refresh (0.5s interval)
  shuttle export 1            # export session 1 as markdown
  shuttle export 1 --json --file out.json  # export to JSON file
  shuttle extract-pairs --all --output pairs.jsonl  # training data from all sessions
  shuttle extract-pairs --project shuttle --stats   # stats for shuttle sessions
  shuttle send 1 "check the failing tests"  # nudge a session
  shuttle send 2 "skein torch"  # trigger retirement
  shuttle whoami              # get unique probe (run from inside session)
  shuttle confirm SESSION_PROBE_abc123  # find session containing probe
  shuttle score-sessions               # top 20 interactive sessions by signal
  shuttle score-sessions -p speakbot -s 7  # speakbot sessions, last 7 days
  shuttle score-sessions --json        # output as JSON
  shuttle kill diverge        # kill session matching 'diverge'
EOF
        ;;

    extract-pairs|ep)
        # Extract (context, response) training pairs from CC session JSONL files
        SHUTTLE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
        exec python3 -c "
import sys
sys.path.insert(0, '$SHUTTLE_ROOT')
from parser.extract_pairs import main
sys.exit(main(sys.argv[1:]))
" "$@"
        ;;

    *)
        echo "Unknown command: $CMD"
        echo "Run 'shuttle help' for usage"
        exit 1
        ;;
esac

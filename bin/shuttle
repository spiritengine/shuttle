#!/bin/bash
# shuttle - CLI for managing Claude Code agent sessions
# Usage: shuttle [command] [args]

set -e

# =============================================================================
# Configuration
# =============================================================================

# Default configuration values
SHUTTLE_DEFAULT_PROJECT=""           # Default project directory (empty = use pwd)
SHUTTLE_DEFAULT_SITE="ledger"        # Default site for briefs
SHUTTLE_TERMINAL="gnome-terminal --" # Terminal emulator command
SHUTTLE_HEADLESS_DEFAULT=""          # Default headless mode (empty = auto-detect)
SHUTTLE_PROMPT_TIMEOUT=12            # Seconds to wait for Claude prompt

# Config file locations (checked in order)
SHUTTLE_CONFIG_PATHS=(
    "${XDG_CONFIG_HOME:-$HOME/.config}/shuttle/config"
    "$HOME/.shuttlerc"
)

# Load configuration from file if it exists
load_config() {
    for config_path in "${SHUTTLE_CONFIG_PATHS[@]}"; do
        if [ -f "$config_path" ]; then
            # Source bash-style KEY=value config
            # shellcheck disable=SC1090
            source "$config_path"
            SHUTTLE_LOADED_CONFIG="$config_path"
            return 0
        fi
    done
    SHUTTLE_LOADED_CONFIG=""
    return 0
}

# Get effective config value (precedence: env var > config file > default)
# After load_config, variables are already set via sourcing
# Env vars with same name will override (since they're not overwritten by source)

# Load config at startup (before any command processing)
load_config

# Apply environment variable overrides (higher precedence than config file)
[ -n "$SHUTTLE_PROJECT" ] && SHUTTLE_DEFAULT_PROJECT="$SHUTTLE_PROJECT"
[ -n "$SHUTTLE_SITE" ] && SHUTTLE_DEFAULT_SITE="$SHUTTLE_SITE"
[ -n "$SHUTTLE_TERM" ] && SHUTTLE_TERMINAL="$SHUTTLE_TERM"
[ -n "$SHUTTLE_TIMEOUT" ] && SHUTTLE_PROMPT_TIMEOUT="$SHUTTLE_TIMEOUT"

# =============================================================================
# Helper Functions
# =============================================================================

# Parse --dir, --project, and --headless options
# Sets: PROJECT_DIR, HEADLESS, remaining args in POSITIONAL array
parse_project_opts() {
    PROJECT_DIR=""
    PROJECT_NAME=""
    HEADLESS=""
    POSITIONAL=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--dir)
                PROJECT_DIR="$2"
                shift 2
                ;;
            -p|--project)
                PROJECT_NAME="$2"
                shift 2
                ;;
            --headless)
                HEADLESS=1
                shift
                ;;
            *)
                POSITIONAL+=("$1")
                shift
                ;;
        esac
    done

    # Error if both set
    if [ -n "$PROJECT_DIR" ] && [ -n "$PROJECT_NAME" ]; then
        echo "Error: cannot use both --dir and --project"
        exit 1
    fi

    # Resolve project name to path
    if [ -n "$PROJECT_NAME" ]; then
        PROJECT_DIR="$HOME/projects/$PROJECT_NAME"
        if [ ! -d "$PROJECT_DIR" ]; then
            echo "Error: project not found: $PROJECT_DIR"
            exit 1
        fi
    fi

    # Default: config default project, or current directory
    if [ -z "$PROJECT_DIR" ]; then
        if [ -n "$SHUTTLE_DEFAULT_PROJECT" ]; then
            PROJECT_DIR="${SHUTTLE_DEFAULT_PROJECT/#\~/$HOME}"
            if [ ! -d "$PROJECT_DIR" ]; then
                echo "Warning: default_project not found: $PROJECT_DIR (using pwd)"
                PROJECT_DIR="$(pwd)"
            fi
        else
            PROJECT_DIR="$(pwd)"
        fi
    fi

    # Headless: explicit flag, env var, config default, or no display
    if [ -n "$SHUTTLE_HEADLESS" ] || [ -n "$SHUTTLE_HEADLESS_DEFAULT" ] || [ -z "$DISPLAY" ]; then
        HEADLESS=1
    fi
}

# Send a message to a tmux pane and press Enter
# Usage: tmux_send_cmd <target> <message>
# NOTE: Must use two separate send-keys calls when using -t target!
# Single-line "message" Enter doesn't work reliably with -t flag.
tmux_send_cmd() {
    local target="$1"
    local message="$2"
    tmux send-keys -t "$target" "$message"
    sleep 0.1
    tmux send-keys -t "$target" Enter
}

# Launch terminal with given command
# Uses configured SHUTTLE_TERMINAL, with dbus-launch wrapper for gnome-terminal
launch_terminal() {
    local cmd="$1"
    if [[ "$SHUTTLE_TERMINAL" == gnome-terminal* ]]; then
        dbus-launch $SHUTTLE_TERMINAL $cmd 2>/dev/null
    else
        $SHUTTLE_TERMINAL $cmd 2>/dev/null
    fi
}

# Format seconds as relative time (e.g., "2m ago", "1h ago")
format_age() {
    local seconds=$1
    if [ "$seconds" -lt 60 ]; then
        echo "${seconds}s"
    elif [ "$seconds" -lt 3600 ]; then
        echo "$((seconds / 60))m"
    elif [ "$seconds" -lt 86400 ]; then
        echo "$((seconds / 3600))h"
    else
        echo "$((seconds / 86400))d"
    fi
}

# Detect Claude Code session state from pane content
detect_session_state() {
    local session="$1"
    local idle_seconds="$2"

    # Capture last 30 lines from the pane
    local content
    content=$(tmux capture-pane -t "$session" -p 2>/dev/null | tail -30)

    if [ -z "$content" ]; then
        echo "unknown"
        return
    fi

    # Check for approval prompt (highest priority - needs human action)
    if echo "$content" | grep -qE "Do you want to proceed\?|❯ 1\. Yes|Allow once|Allow always"; then
        echo "approval"
        return
    fi

    # Check for actively working indicators
    if echo "$content" | grep -qE "\(esc to interrupt|Running…|✶ [A-Z].*…|✻ [A-Z].*…|\* [A-Z].*…"; then
        echo "working"
        return
    fi

    # Check for waiting at prompt
    if echo "$content" | tail -5 | grep -qE "^>"; then
        echo "waiting"
        return
    fi

    # Check for stuck (idle for more than 5 minutes with no clear state)
    if [ "$idle_seconds" -gt 300 ]; then
        echo "stuck"
        return
    fi

    echo "unknown"
}

# Format state with symbol
format_state() {
    local state="$1"
    case "$state" in
        working)  echo "⚡" ;;
        approval) echo "🔒" ;;
        waiting)  echo "💤" ;;
        stuck)    echo "⚠️ " ;;
        *)        echo "○" ;;
    esac
}

CMD="${1:-status}"
shift 2>/dev/null || true

case "$CMD" in
    status)
        # Start slow skein calls in parallel
        BRIEFS_TMP=$(mktemp)
        SHARDS_TMP=$(mktemp)
        trap "rm -f $BRIEFS_TMP $SHARDS_TMP" EXIT

        (skein folios "$SHUTTLE_DEFAULT_SITE" --type brief --status open 2>/dev/null | grep "brief-" | head -5 > "$BRIEFS_TMP") &
        BRIEFS_PID=$!
        (skein shard triage 2>/dev/null | tail -n +3 > "$SHARDS_TMP") &
        SHARDS_PID=$!

        # Sessions with activity info
        echo "SESSIONS:"
        NOW=$(date +%s)
        SESSIONS=$(tmux list-sessions -F '#{session_name}|#{session_attached}|#{session_activity}' 2>/dev/null || true)
        if [ -z "$SESSIONS" ]; then
            echo "  (none)"
        else
            i=1
            while IFS='|' read -r NAME ATTACHED ACTIVITY; do
                IDLE=$((NOW - ACTIVITY))
                AGE=$(format_age $IDLE)
                if [ "$ATTACHED" -eq 1 ]; then
                    ATTACH_STR="attached"
                else
                    ATTACH_STR="detached"
                fi
                # Detect session state from pane content
                STATE=$(detect_session_state "$NAME" "$IDLE")
                INDICATOR=$(format_state "$STATE")
                printf "  [%d] %-30s (%s)  %4s %s\n" "$i" "$NAME" "$ATTACH_STR" "$AGE" "$INDICATOR"
                ((i++))
            done <<< "$SESSIONS"
        fi
        echo ""

        # Wait for briefs and display
        wait $BRIEFS_PID 2>/dev/null
        echo "READY BRIEFS:"
        if [ -s "$BRIEFS_TMP" ]; then
            while read -r line; do
                echo "  $line"
            done < "$BRIEFS_TMP"
        else
            echo "  (none)"
        fi
        echo ""

        # Wait for shards and display
        wait $SHARDS_PID 2>/dev/null
        echo "SHARDS:"
        TRIAGE=$(cat "$SHARDS_TMP")
        if [ -z "$TRIAGE" ]; then
            echo "  (unavailable)"
        else
            READY=$(echo "$TRIAGE" | grep -c "✓" 2>/dev/null || true)
            CONFLICT=$(echo "$TRIAGE" | grep -c "⚠" 2>/dev/null || true)
            EMPTY=$(echo "$TRIAGE" | grep -c "empty" 2>/dev/null || true)
            echo "  ${READY:-0} ready, ${CONFLICT:-0} conflicts, ${EMPTY:-0} empty"
        fi
        ;;

    ls|list)
        tmux ls 2>/dev/null | nl -w2 -s'] ' | sed 's/^/[/' || echo "(no sessions)"
        ;;

    board|b)
        # Check for --headless flag
        HEADLESS=""
        TARGET=""
        for arg in "$@"; do
            if [ "$arg" = "--headless" ]; then
                HEADLESS=1
            else
                TARGET="$arg"
            fi
        done
        # Also check env var and display
        if [ -n "$SHUTTLE_HEADLESS" ] || [ -z "$DISPLAY" ]; then
            HEADLESS=1
        fi

        if [ -z "$TARGET" ]; then
            echo "Usage: shuttle board [--headless] <number|name>"
            exit 1
        fi

        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$TARGET" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $TARGET"
            exit 1
        fi

        echo "Boarding $SESSION..."
        if [ -n "$HEADLESS" ]; then
            tmux attach -t "$SESSION"
        else
            launch_terminal "tmux attach -t $SESSION"
        fi
        ;;

    kill|k)
        if [ -z "$1" ]; then
            echo "Usage: shuttle kill <number|name>"
            exit 1
        fi

        if [[ "$1" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${1}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$1" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $1"
            exit 1
        fi

        echo "Killing $SESSION..."
        tmux kill-session -t "$SESSION"
        echo "Done."
        ;;

    send)
        if [ -z "$1" ] || [ -z "$2" ]; then
            echo "Usage: shuttle send <number|name> <message>"
            exit 1
        fi

        TARGET="$1"
        MESSAGE="$2"

        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$TARGET" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $TARGET"
            exit 1
        fi

        echo "Sending to $SESSION: $MESSAGE"
        tmux_send_cmd "$SESSION" "$MESSAGE"
        ;;

    relay)
        NO_ENTER=""
        POSITIONAL=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --no-enter|-n)
                    NO_ENTER=1
                    shift
                    ;;
                *)
                    POSITIONAL+=("$1")
                    shift
                    ;;
            esac
        done
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ] || [ -z "$2" ]; then
            echo "Usage: shuttle relay [--no-enter] <number|name> <file|->"
            echo "  --no-enter, -n  Paste without pressing Enter"
            echo "  Use '-' to read from stdin"
            exit 1
        fi

        TARGET="$1"
        FILE="$2"

        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$TARGET" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $TARGET"
            exit 1
        fi

        # Read content from file or stdin
        if [ "$FILE" = "-" ]; then
            CONTENT=$(cat)
        elif [ ! -f "$FILE" ]; then
            echo "File not found: $FILE"
            exit 1
        else
            CONTENT=$(cat "$FILE")
        fi

        # Check size (warn if > 10KB)
        SIZE=${#CONTENT}
        if [ "$SIZE" -gt 10240 ]; then
            echo "Warning: Large content ($SIZE bytes) - may be slow"
        fi

        echo "Relaying to $SESSION ($SIZE bytes)..."
        if [ -n "$NO_ENTER" ]; then
            tmux send-keys -t "$SESSION" "$CONTENT"
        else
            tmux_send_cmd "$SESSION" "$CONTENT"
        fi
        echo "Done."
        ;;

    context|ctx)
        TARGET="${1:-1}"
        LAST_N="${2:-10}"

        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$TARGET" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $TARGET"
            exit 1
        fi

        # Get session's working directory
        CWD=$(tmux display-message -t "$SESSION" -p '#{pane_current_path}' 2>/dev/null)
        if [ -z "$CWD" ]; then
            echo "Could not get session working directory"
            exit 1
        fi

        # Convert to CC's project path format: /home/patrick/foo → -home-patrick-foo
        PROJECT_PATH=$(echo "$CWD" | sed 's|^/||; s|/|-|g; s|^|-|')
        CC_PROJECT_DIR="$HOME/.claude/projects/$PROJECT_PATH"

        if [ ! -d "$CC_PROJECT_DIR" ]; then
            echo "No CC history found for: $CWD"
            exit 1
        fi

        # Find most recent session file (excluding agent- files which are subagents)
        SESSION_FILE=$(ls -t "$CC_PROJECT_DIR"/*.jsonl 2>/dev/null | grep -v '/agent-' | head -1)
        if [ -z "$SESSION_FILE" ]; then
            echo "No session files found"
            exit 1
        fi

        echo "=== $SESSION context (last $LAST_N messages) ==="
        echo "=== from: $(basename "$SESSION_FILE") ==="
        echo ""

        # Extract and format messages
        tail -n "$LAST_N" "$SESSION_FILE" | while IFS= read -r line; do
            TYPE=$(echo "$line" | jq -r '.type // "unknown"' 2>/dev/null)
            ROLE=$(echo "$line" | jq -r '.message.role // ""' 2>/dev/null)

            if [ "$TYPE" = "user" ] && [ "$ROLE" = "user" ]; then
                # User content can be string or array - extract text, skip tool_results
                CONTENT=$(echo "$line" | jq -r '
                    .message.content |
                    if type == "string" then .
                    elif type == "array" then
                        [.[] | select(.type == "text") | .text] | join("\n")
                    else ""
                    end
                ' 2>/dev/null)
                if [ -n "$CONTENT" ] && [ "$CONTENT" != "null" ]; then
                    echo "USER: $CONTENT"
                    echo ""
                fi
            elif [ "$TYPE" = "assistant" ] && [ "$ROLE" = "assistant" ]; then
                # Get text content from assistant (skip tool use blocks)
                CONTENT=$(echo "$line" | jq -r '
                    [.message.content[] | select(.type == "text") | .text] | join("\n")
                ' 2>/dev/null | head -c 800)
                if [ -n "$CONTENT" ] && [ "$CONTENT" != "null" ]; then
                    echo "CLAUDE: $CONTENT"
                    echo ""
                fi
            fi
        done
        ;;

    search)
        SHUTTLE_INDEX_FILE="$HOME/.shuttle/index.json"
        CC_PROJECTS="$HOME/.claude/projects"

        # Parse options
        QUERY=""
        SEARCH_ALL=""
        LIST_MODE=""
        SINCE_FILTER=""
        PROJECT_FILTER=""
        LIMIT=20

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --all|-a)
                    SEARCH_ALL=1
                    shift
                    ;;
                --list|-l)
                    LIST_MODE=1
                    shift
                    ;;
                --since|-s)
                    SINCE_FILTER="$2"
                    shift 2
                    ;;
                --project|-p)
                    PROJECT_FILTER="$2"
                    shift 2
                    ;;
                --limit|-n)
                    LIMIT="$2"
                    shift 2
                    ;;
                -*)
                    echo "Unknown option: $1"
                    echo "Usage: shuttle search [query] [options]"
                    echo "  --all, -a        Search all projects (default: current project)"
                    echo "  --list, -l       List sessions from index (no content search)"
                    echo "  --since, -s N    Only sessions from last N days"
                    echo "  --project, -p P  Filter by project path (substring match)"
                    echo "  --limit, -n N    Limit results (default: 20)"
                    exit 1
                    ;;
                *)
                    QUERY="$1"
                    shift
                    ;;
            esac
        done

        # Check if index exists
        if [ ! -f "$SHUTTLE_INDEX_FILE" ]; then
            echo "No index found. Run 'shuttle index' first."
            exit 1
        fi

        # Build jq filter for index queries
        JQ_FILTER='.sessions | to_entries[]'

        # Project filter
        if [ -n "$PROJECT_FILTER" ]; then
            JQ_FILTER="$JQ_FILTER | select(.value.project | contains(\"$PROJECT_FILTER\"))"
        elif [ -z "$SEARCH_ALL" ]; then
            # Default: current project
            CURRENT_PROJECT=$(pwd)
            JQ_FILTER="$JQ_FILTER | select(.value.project | startswith(\"$CURRENT_PROJECT\"))"
        fi

        # Date filter
        if [ -n "$SINCE_FILTER" ]; then
            SINCE_EPOCH=$(($(date +%s) - (SINCE_FILTER * 86400)))
            JQ_FILTER="$JQ_FILTER | select(.value.mtime >= $SINCE_EPOCH)"
        fi

        # Sort by last activity (most recent first)
        JQ_FILTER="[$JQ_FILTER] | sort_by(.value.mtime) | reverse"

        # Limit results
        JQ_FILTER="$JQ_FILTER | .[:$LIMIT]"

        if [ -n "$LIST_MODE" ]; then
            # List mode: show sessions from index without content search
            echo "Sessions from index:"
            echo ""
            # Use tab delimiter for safe parsing
            jq -r "$JQ_FILTER | .[] | \"\(.key)\t\(.value.mtime)\t\(.value.project)\t\(.value.summary[0:50] | gsub(\"[\\n\\t]\"; \" \"))\"" "$SHUTTLE_INDEX_FILE" 2>/dev/null | while IFS=$'\t' read -r ID MTIME PROJECT SUMMARY; do
                NOW=$(date +%s)
                AGE=$(( (NOW - MTIME) / 86400 ))
                if [ "$AGE" -eq 0 ]; then
                    AGE_STR="today"
                elif [ "$AGE" -eq 1 ]; then
                    AGE_STR="1d ago"
                else
                    AGE_STR="${AGE}d ago"
                fi
                # Extract just project name
                PROJ_NAME=$(basename "$PROJECT")
                printf "%-38s %-10s %-15s %s\n" "$ID" "$AGE_STR" "$PROJ_NAME" "$SUMMARY"
            done
        else
            # Content search: use index to get files, then grep
            if [ -z "$QUERY" ]; then
                echo "Usage: shuttle search <query> [options]"
                echo "  Or use --list to list sessions without searching content"
                exit 1
            fi

            echo "Searching for: $QUERY"
            echo ""

            # Get files from index, then grep them
            jq -r "$JQ_FILTER | .[].value.file" "$SHUTTLE_INDEX_FILE" 2>/dev/null | while read -r FILE; do
                if [ ! -f "$FILE" ]; then
                    continue
                fi

                if ! grep -q "$QUERY" "$FILE" 2>/dev/null; then
                    continue
                fi

                SESSION_ID=$(basename "$FILE" .jsonl)
                PROJECT=$(jq -r ".sessions[\"$SESSION_ID\"].project" "$SHUTTLE_INDEX_FILE" 2>/dev/null)

                # Get file modification time
                MOD_TIME=$(stat -c %Y "$FILE" 2>/dev/null)
                NOW=$(date +%s)
                AGE=$(( (NOW - MOD_TIME) / 86400 ))
                if [ "$AGE" -eq 0 ]; then
                    AGE_STR="today"
                elif [ "$AGE" -eq 1 ]; then
                    AGE_STR="yesterday"
                else
                    AGE_STR="${AGE}d ago"
                fi

                echo "=== $SESSION_ID ($AGE_STR) ==="
                echo "    project: $PROJECT"

                # Show matching lines with context (text content only)
                grep "$QUERY" "$FILE" 2>/dev/null | head -3 | while read -r line; do
                    TEXT=$(echo "$line" | jq -r '
                        .message.content |
                        if type == "string" then .
                        elif type == "array" then
                            [.[] | select(.type == "text") | .text] | join(" ")
                        else ""
                        end
                    ' 2>/dev/null | head -c 200)
                    if [ -n "$TEXT" ] && [ "$TEXT" != "null" ]; then
                        echo "    ...$TEXT..."
                    fi
                done
                echo ""
            done
        fi
        ;;

    resume)
        if [ -z "$1" ]; then
            echo "Usage: shuttle resume <session-id>"
            echo "  Resume a CC session by UUID (from shuttle search)"
            exit 1
        fi

        SESSION_ID="$1"
        CC_PROJECTS="$HOME/.claude/projects"

        # Find which project contains this session
        SESSION_FILE=$(find "$CC_PROJECTS" -name "${SESSION_ID}.jsonl" -type f 2>/dev/null | head -1)

        if [ -z "$SESSION_FILE" ]; then
            echo "Session not found: $SESSION_ID"
            echo "Use 'shuttle search' to find valid session IDs"
            exit 1
        fi

        # Extract project path from encoded folder name
        # ~/.claude/projects/-home-patrick-projects-foo/uuid.jsonl → /home/patrick/projects/foo
        ENCODED_PATH=$(basename "$(dirname "$SESSION_FILE")")
        PROJECT_DIR=$(echo "$ENCODED_PATH" | sed 's/^-//; s/-/\//g')
        PROJECT_DIR="/$PROJECT_DIR"

        if [ ! -d "$PROJECT_DIR" ]; then
            echo "Project directory not found: $PROJECT_DIR"
            exit 1
        fi

        # Create session name from project
        PROJECT_NAME=$(basename "$PROJECT_DIR")
        TMUX_SESSION="resume-${PROJECT_NAME}-${SESSION_ID:0:8}"

        echo "Resuming session $SESSION_ID"
        echo "  Project: $PROJECT_DIR"
        echo "  Tmux: $TMUX_SESSION"

        # Launch CC with --resume in new tmux session
        tmux new-session -d -s "$TMUX_SESSION" -c "$PROJECT_DIR" "claude --resume $SESSION_ID"

        # Wait for claude to start
        sleep 1

        # Open terminal or print attach instructions
        if [ -n "$HEADLESS" ] || [ -n "$SHUTTLE_HEADLESS" ] || [ -z "$DISPLAY" ]; then
            echo "Attach with: tmux attach -t $TMUX_SESSION"
        else
            launch_terminal "tmux attach -t $TMUX_SESSION"
            echo "Launched $TMUX_SESSION"
        fi
        ;;

    export|x)
        # Parse options
        OUTPUT_FORMAT="markdown"
        OUTPUT_FILE=""
        LAST_N=""
        POSITIONAL=()

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --json|-j)
                    OUTPUT_FORMAT="json"
                    shift
                    ;;
                --file|-f)
                    OUTPUT_FILE="$2"
                    shift 2
                    ;;
                --last|-l)
                    LAST_N="$2"
                    shift 2
                    ;;
                *)
                    POSITIONAL+=("$1")
                    shift
                    ;;
            esac
        done
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ]; then
            echo "Usage: shuttle export <n|session-id> [options]"
            echo "  Export a CC session to markdown or JSON"
            echo ""
            echo "Options:"
            echo "  --json, -j        Output as JSON instead of markdown"
            echo "  --file, -f FILE   Write to file instead of stdout"
            echo "  --last, -l N      Only include last N messages"
            echo ""
            echo "Examples:"
            echo "  shuttle export 1                    # export session 1 as markdown"
            echo "  shuttle export 1 --json             # export as JSON"
            echo "  shuttle export abc123-uuid --file out.md"
            echo "  shuttle export 1 --last 20          # last 20 messages only"
            exit 1
        fi

        TARGET="$1"
        CC_PROJECTS="$HOME/.claude/projects"

        # Determine if target is tmux session number/name or raw UUID
        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            # Numeric: treat as tmux session index
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
            if [ -z "$SESSION" ]; then
                echo "Session not found: $TARGET"
                exit 1
            fi
            # Get session's working directory
            CWD=$(tmux display-message -t "$SESSION" -p '#{pane_current_path}' 2>/dev/null)
            if [ -z "$CWD" ]; then
                echo "Could not get session working directory"
                exit 1
            fi
            # Convert to CC project path
            PROJECT_PATH=$(echo "$CWD" | sed 's|^/||; s|/|-|g; s|^|-|')
            CC_PROJECT_DIR="$CC_PROJECTS/$PROJECT_PATH"
            if [ ! -d "$CC_PROJECT_DIR" ]; then
                echo "No CC history found for: $CWD"
                exit 1
            fi
            # Find most recent session file
            SESSION_FILE=$(ls -t "$CC_PROJECT_DIR"/*.jsonl 2>/dev/null | grep -v '/agent-' | head -1)
            SESSION_ID=$(basename "$SESSION_FILE" .jsonl)
        elif tmux has-session -t "$TARGET" 2>/dev/null; then
            # Matches a tmux session name
            CWD=$(tmux display-message -t "$TARGET" -p '#{pane_current_path}' 2>/dev/null)
            if [ -z "$CWD" ]; then
                echo "Could not get session working directory"
                exit 1
            fi
            PROJECT_PATH=$(echo "$CWD" | sed 's|^/||; s|/|-|g; s|^|-|')
            CC_PROJECT_DIR="$CC_PROJECTS/$PROJECT_PATH"
            if [ ! -d "$CC_PROJECT_DIR" ]; then
                echo "No CC history found for: $CWD"
                exit 1
            fi
            SESSION_FILE=$(ls -t "$CC_PROJECT_DIR"/*.jsonl 2>/dev/null | grep -v '/agent-' | head -1)
            SESSION_ID=$(basename "$SESSION_FILE" .jsonl)
        else
            # Treat as UUID - search for it
            SESSION_ID="$TARGET"
            SESSION_FILE=$(find "$CC_PROJECTS" -name "${SESSION_ID}.jsonl" -type f 2>/dev/null | head -1)
            if [ -z "$SESSION_FILE" ]; then
                # Try partial match
                SESSION_FILE=$(find "$CC_PROJECTS" -name "*.jsonl" -type f 2>/dev/null | grep "$SESSION_ID" | head -1)
            fi
        fi

        if [ -z "$SESSION_FILE" ] || [ ! -f "$SESSION_FILE" ]; then
            echo "Session file not found: $TARGET"
            echo "Use 'shuttle search' to find valid session IDs"
            exit 1
        fi

        # Extract metadata
        ENCODED_PATH=$(basename "$(dirname "$SESSION_FILE")")
        PROJECT=$(echo "$ENCODED_PATH" | sed 's/^-//; s/-/\//g')
        PROJECT="/$PROJECT"
        FILE_DATE=$(stat -c %Y "$SESSION_FILE" 2>/dev/null)
        DATE_STR=$(date -d "@$FILE_DATE" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || date -r "$FILE_DATE" "+%Y-%m-%d %H:%M:%S")

        # Read messages (optionally limited)
        if [ -n "$LAST_N" ]; then
            MESSAGES=$(tail -n "$LAST_N" "$SESSION_FILE")
        else
            MESSAGES=$(cat "$SESSION_FILE")
        fi

        # Generate output
        if [ "$OUTPUT_FORMAT" = "json" ]; then
            # JSON output: array of cleaned message objects
            OUTPUT=$(echo "$MESSAGES" | jq -s --arg session "$SESSION_ID" --arg project "$PROJECT" --arg date "$DATE_STR" '
                {
                    session_id: $session,
                    project: $project,
                    date: $date,
                    messages: [
                        .[] |
                        select(.type == "user" or .type == "assistant") |
                        {
                            role: .message.role,
                            content: (
                                if .message.content | type == "string" then
                                    .message.content
                                elif .message.content | type == "array" then
                                    [.message.content[] | select(.type == "text") | .text] | join("\n")
                                else
                                    ""
                                end
                            )
                        } |
                        select(.content != "" and .content != null)
                    ]
                }
            ' 2>/dev/null)
        else
            # Markdown output
            OUTPUT="# Session: $SESSION_ID

Project: $PROJECT
Date: $DATE_STR

---
"
            # Process each message
            while IFS= read -r line; do
                TYPE=$(echo "$line" | jq -r '.type // "unknown"' 2>/dev/null)
                ROLE=$(echo "$line" | jq -r '.message.role // ""' 2>/dev/null)

                if [ "$TYPE" = "user" ] && [ "$ROLE" = "user" ]; then
                    CONTENT=$(echo "$line" | jq -r '
                        .message.content |
                        if type == "string" then .
                        elif type == "array" then
                            [.[] | select(.type == "text") | .text] | join("\n")
                        else ""
                        end
                    ' 2>/dev/null)
                    if [ -n "$CONTENT" ] && [ "$CONTENT" != "null" ]; then
                        OUTPUT+="
## User

$CONTENT

"
                    fi
                elif [ "$TYPE" = "assistant" ] && [ "$ROLE" = "assistant" ]; then
                    CONTENT=$(echo "$line" | jq -r '
                        [.message.content[] | select(.type == "text") | .text] | join("\n")
                    ' 2>/dev/null)
                    if [ -n "$CONTENT" ] && [ "$CONTENT" != "null" ]; then
                        OUTPUT+="
## Claude

$CONTENT

"
                    fi
                fi
            done <<< "$MESSAGES"
        fi

        # Output to file or stdout
        if [ -n "$OUTPUT_FILE" ]; then
            echo "$OUTPUT" > "$OUTPUT_FILE"
            echo "Exported to: $OUTPUT_FILE"
            if [ "$OUTPUT_FORMAT" = "json" ]; then
                MSG_COUNT=$(echo "$OUTPUT" | jq '.messages | length' 2>/dev/null || echo "?")
            else
                MSG_COUNT=$(echo "$OUTPUT" | grep -c "^## " || echo "?")
            fi
            echo "  Session: $SESSION_ID"
            echo "  Messages: $MSG_COUNT"
        else
            echo "$OUTPUT"
        fi
        ;;

    peek|p)
        TARGET="${1:-1}"
        LINES="${2:-20}"

        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$TARGET" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $TARGET"
            exit 1
        fi

        echo "=== $SESSION (last $LINES lines) ==="
        tmux capture-pane -t "$SESSION" -p | tail -n "$LINES"
        ;;

    tail|t)
        TARGET="${1:-1}"
        INTERVAL="${2:-1}"

        if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
            SESSION=$(tmux ls 2>/dev/null | sed -n "${TARGET}p" | cut -d: -f1)
        else
            SESSION=$(tmux ls 2>/dev/null | grep "$TARGET" | head -1 | cut -d: -f1)
        fi

        if [ -z "$SESSION" ]; then
            echo "Session not found: $TARGET"
            exit 1
        fi

        echo "=== Tailing $SESSION (Ctrl-C to exit) ==="

        # We track content by keeping a hash of the last capture
        # and only showing new lines when content changes
        LAST_HASH=""
        LAST_LINE_COUNT=0

        # Capture full pane including scrollback (-S - starts from beginning)
        # Use temporary file to handle multi-line content properly
        CAPTURE_FILE=$(mktemp)
        trap "rm -f $CAPTURE_FILE" EXIT

        while true; do
            # Capture current pane content (full scrollback)
            tmux capture-pane -t "$SESSION" -p -S - > "$CAPTURE_FILE" 2>/dev/null

            # Get current line count
            CURRENT_LINE_COUNT=$(wc -l < "$CAPTURE_FILE")

            # Get hash of content to detect changes
            CURRENT_HASH=$(md5sum "$CAPTURE_FILE" | cut -d' ' -f1)

            if [ "$CURRENT_HASH" != "$LAST_HASH" ]; then
                # Content changed - show new lines
                if [ "$LAST_LINE_COUNT" -gt 0 ]; then
                    # Show only lines after what we've already seen
                    NEW_LINES=$((CURRENT_LINE_COUNT - LAST_LINE_COUNT))
                    if [ "$NEW_LINES" -gt 0 ]; then
                        tail -n "$NEW_LINES" "$CAPTURE_FILE"
                    elif [ "$NEW_LINES" -lt 0 ]; then
                        # Screen was cleared or scrollback reduced - show recent context
                        echo "--- (screen cleared) ---"
                        tail -n 5 "$CAPTURE_FILE"
                    fi
                else
                    # First capture - show last 10 lines for context
                    tail -n 10 "$CAPTURE_FILE"
                fi

                LAST_HASH="$CURRENT_HASH"
                LAST_LINE_COUNT="$CURRENT_LINE_COUNT"
            fi

            sleep "$INTERVAL"
        done
        ;;

    go|g)
        parse_project_opts "$@"
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ]; then
            echo "Usage: shuttle go [--dir PATH | --project NAME] <brief-id>"
            exit 1
        fi
        BRIEF_ID="$1"

        # Get brief title for human-readable session name
        BRIEF_TITLE=$(skein folio "$BRIEF_ID" 2>/dev/null | grep "^    #" | head -1 | sed 's/^[[:space:]]*#[[:space:]]*//' | tr ' ' '-' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g' | sed 's/--*/-/g' | cut -c1-25)

        if [ -z "$BRIEF_TITLE" ]; then
            SESSION="shuttle-${BRIEF_ID}"
        else
            SESSION="shuttle-${BRIEF_TITLE}"
        fi

        # Check if session already exists - reboard instead of creating new
        if tmux has-session -t "$SESSION" 2>/dev/null; then
            echo "Session '$SESSION' exists - reboarding..."
            if [ -n "$HEADLESS" ]; then
                echo "Attach with: tmux attach -t $SESSION"
            else
                launch_terminal "tmux attach -t $SESSION"
            fi
            exit 0
        fi

        echo "Launching: $SESSION (in $PROJECT_DIR)"

        # Create new tmux session running claude
        tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR" "claude"

        # Wait for claude prompt to appear (timeout based on config)
        echo "Waiting for Claude..."
        MAX_ITERATIONS=$((SHUTTLE_PROMPT_TIMEOUT * 5))  # 5 checks per second
        for ((i=1; i<=MAX_ITERATIONS; i++)); do
            CAPTURED=$(tmux capture-pane -t "$SESSION" -p)
            # Look for Claude's prompt or shortcuts hint
            if echo "$CAPTURED" | grep -qE "^>|? for"; then
                echo "Ready!"
                break
            fi
            sleep 0.2
        done

        # Send the HANDOFF message
        tmux_send_cmd "$SESSION" "HANDOFF: $BRIEF_ID"

        # Open terminal or print attach instructions
        if [ -n "$HEADLESS" ]; then
            echo "Session ready: $SESSION"
            echo "Attach with: tmux attach -t $SESSION"
        else
            launch_terminal "tmux attach -t $SESSION"
            echo "Launched $SESSION"
        fi
        ;;

    split|s|vsplit|vs)
        # Determine split direction
        if [[ "$CMD" == "vsplit" || "$CMD" == "vs" ]]; then
            SPLIT_FLAG="-v"
            SPLIT_TYPE="vertical"
        else
            SPLIT_FLAG="-h"
            SPLIT_TYPE="horizontal"
        fi

        parse_project_opts "$@"
        set -- "${POSITIONAL[@]}"

        if [ -z "$1" ]; then
            echo "Usage: shuttle $CMD [--dir PATH | --project NAME] <brief-id>"
            exit 1
        fi

        if [ -z "$TMUX" ]; then
            echo "Error: $CMD requires being inside a tmux session"
            echo "Use 'shuttle go <brief>' to launch in a new window instead"
            exit 1
        fi

        BRIEF_ID="$1"
        echo "Opening $SPLIT_TYPE split for $BRIEF_ID (in $PROJECT_DIR)..."

        # Create split running claude, capture the new pane ID
        NEW_PANE=$(tmux split-window $SPLIT_FLAG -c "$PROJECT_DIR" -P -F '#{pane_id}' "claude")

        # Wait for claude prompt in the NEW pane (timeout based on config)
        echo "Waiting for Claude..."
        MAX_ITERATIONS=$((SHUTTLE_PROMPT_TIMEOUT * 5))  # 5 checks per second
        for ((i=1; i<=MAX_ITERATIONS; i++)); do
            CAPTURED=$(tmux capture-pane -t "$NEW_PANE" -p)
            # Look for Claude's prompt or shortcuts hint
            if echo "$CAPTURED" | grep -qE "^>|? for"; then
                break
            fi
            sleep 0.2
        done

        # Send the HANDOFF to the specific pane we created
        tmux_send_cmd "$NEW_PANE" "HANDOFF: $BRIEF_ID"
        echo "Split opened. Use 'shuttle unsplit' to close."
        ;;

    unsplit)
        if [ -z "$TMUX" ]; then
            echo "Error: unsplit requires being inside a tmux session"
            exit 1
        fi

        PANE_COUNT=$(tmux list-panes | wc -l)
        if [ "$PANE_COUNT" -eq 1 ]; then
            echo "No split pane to close"
            exit 0
        fi

        # Kill the other pane (not the current one)
        CURRENT_PANE=$(tmux display-message -p '#{pane_index}')
        if [ "$CURRENT_PANE" -eq 0 ]; then
            tmux kill-pane -t 1
        else
            tmux kill-pane -t 0
        fi
        echo "Split closed."
        ;;

    watch|w)
        while true; do
            clear
            "$0" status
            sleep 2
        done
        ;;

    ground)
        tmux ls 2>/dev/null | grep "^shuttle-" | cut -d: -f1 | while read -r sess; do
            echo "  Killing $sess"
            tmux kill-session -t "$sess"
        done
        echo "Done."
        ;;

    config|cfg)
        echo "SHUTTLE CONFIGURATION"
        echo ""
        if [ -n "$SHUTTLE_LOADED_CONFIG" ]; then
            echo "Config file: $SHUTTLE_LOADED_CONFIG"
        else
            echo "Config file: (none found)"
            echo "  Checked locations:"
            for path in "${SHUTTLE_CONFIG_PATHS[@]}"; do
                echo "    - $path"
            done
        fi
        echo ""
        echo "Current settings:"
        echo "  SHUTTLE_DEFAULT_PROJECT = ${SHUTTLE_DEFAULT_PROJECT:-(not set, uses pwd)}"
        echo "  SHUTTLE_DEFAULT_SITE    = $SHUTTLE_DEFAULT_SITE"
        echo "  SHUTTLE_TERMINAL        = $SHUTTLE_TERMINAL"
        echo "  SHUTTLE_HEADLESS_DEFAULT= ${SHUTTLE_HEADLESS_DEFAULT:-(auto-detect)}"
        echo "  SHUTTLE_PROMPT_TIMEOUT  = ${SHUTTLE_PROMPT_TIMEOUT}s"
        echo ""
        echo "Environment overrides (set these to override config):"
        echo "  SHUTTLE_PROJECT  = ${SHUTTLE_PROJECT:-}"
        echo "  SHUTTLE_SITE     = ${SHUTTLE_SITE:-}"
        echo "  SHUTTLE_TERM     = ${SHUTTLE_TERM:-}"
        echo "  SHUTTLE_HEADLESS = ${SHUTTLE_HEADLESS:-}"
        echo "  SHUTTLE_TIMEOUT  = ${SHUTTLE_TIMEOUT:-}"
        echo ""
        echo "Example config file (~/.config/shuttle/config or ~/.shuttlerc):"
        cat << 'EXAMPLE'
# Shuttle configuration

# Default project directory (empty = use pwd)
SHUTTLE_DEFAULT_PROJECT=~/projects/main

# Default SKEIN site for briefs
SHUTTLE_DEFAULT_SITE=ledger

# Terminal emulator command
SHUTTLE_TERMINAL="gnome-terminal --"

# Always run headless (set to 1, or leave empty for auto-detect)
SHUTTLE_HEADLESS_DEFAULT=

# Prompt detection timeout in seconds
SHUTTLE_PROMPT_TIMEOUT=12
EXAMPLE
        ;;

    index|i)
        # Index all CC sessions for fast search
        SHUTTLE_INDEX_DIR="$HOME/.shuttle"
        SHUTTLE_INDEX_FILE="$SHUTTLE_INDEX_DIR/index.json"
        CC_PROJECTS="$HOME/.claude/projects"

        # Parse options
        UPDATE_MODE=""
        VERBOSE=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --update|-u)
                    UPDATE_MODE=1
                    shift
                    ;;
                --verbose|-v)
                    VERBOSE=1
                    shift
                    ;;
                *)
                    echo "Unknown option: $1"
                    echo "Usage: shuttle index [--update] [--verbose]"
                    exit 1
                    ;;
            esac
        done

        # Create index directory
        mkdir -p "$SHUTTLE_INDEX_DIR"

        # Load existing index for incremental updates
        if [ -n "$UPDATE_MODE" ] && [ -f "$SHUTTLE_INDEX_FILE" ]; then
            EXISTING_INDEX=$(cat "$SHUTTLE_INDEX_FILE")
            # Pre-extract mtimes to temp file for fast lookup (avoids jq per file)
            MTIME_CACHE=$(mktemp)
            jq -r '.sessions | to_entries[] | "\(.key) \(.value.mtime)"' "$SHUTTLE_INDEX_FILE" > "$MTIME_CACHE" 2>/dev/null
            # Also extract existing entries for unchanged files
            ENTRIES_CACHE=$(mktemp)
            jq -r '.sessions | to_entries[] | "\(.key)\t\(.value | @json)"' "$SHUTTLE_INDEX_FILE" > "$ENTRIES_CACHE" 2>/dev/null
            trap "rm -f $MTIME_CACHE $ENTRIES_CACHE" EXIT
            echo "Incremental update mode"
        else
            EXISTING_INDEX='{"version":1,"sessions":{}}'
            MTIME_CACHE=""
            ENTRIES_CACHE=""
            echo "Full index rebuild"
        fi

        # Count files for progress
        TOTAL_FILES=$(find "$CC_PROJECTS" -name "*.jsonl" -type f 2>/dev/null | grep -v '/agent-' | wc -l)
        echo "Found $TOTAL_FILES session files to process"

        # Process each session file
        PROCESSED=0
        SKIPPED=0
        UPDATED=0

        # Create temp file for building index
        INDEX_TMP=$(mktemp)
        trap "rm -f $INDEX_TMP" EXIT

        # Start JSON structure
        echo '{"version":1,"last_updated":"'"$(date -Is)"'","sessions":{' > "$INDEX_TMP"
        FIRST_ENTRY=1

        # Use process substitution to keep loop in main shell (for variable updates)
        while read -r FILE; do
            SESSION_ID=$(basename "$FILE" .jsonl)

            # Get file mtime
            FILE_MTIME=$(stat -c %Y "$FILE" 2>/dev/null)

            # In update mode, check if file changed (using cached mtimes)
            if [ -n "$UPDATE_MODE" ] && [ -n "$MTIME_CACHE" ]; then
                INDEXED_MTIME=$(grep "^$SESSION_ID " "$MTIME_CACHE" 2>/dev/null | cut -d' ' -f2)
                if [ "$FILE_MTIME" = "$INDEXED_MTIME" ]; then
                    # File unchanged, copy existing entry from cache
                    EXISTING_ENTRY=$(grep "^$SESSION_ID	" "$ENTRIES_CACHE" 2>/dev/null | cut -f2)
                    if [ -n "$EXISTING_ENTRY" ]; then
                        if [ "$FIRST_ENTRY" -eq 0 ]; then
                            echo "," >> "$INDEX_TMP"
                        fi
                        echo "\"$SESSION_ID\":$EXISTING_ENTRY" >> "$INDEX_TMP"
                        FIRST_ENTRY=0
                        ((SKIPPED++)) || true
                        continue
                    fi
                fi
            fi

            # Decode project path from directory name
            ENCODED_PATH=$(basename "$(dirname "$FILE")")
            PROJECT=$(echo "$ENCODED_PATH" | sed 's/^-//; s/-/\//g')
            PROJECT="/$PROJECT"

            # Skip empty files
            if [ ! -s "$FILE" ]; then
                continue
            fi

            # Extract metadata from file
            # Get first timestamp and first user message
            FIRST_LINE=$(head -1 "$FILE")
            STARTED=$(echo "$FIRST_LINE" | jq -r '.timestamp // empty' 2>/dev/null)

            # Get first user message for summary
            FIRST_MSG=$(grep '"type":"user"' "$FILE" 2>/dev/null | head -1 | jq -r '
                .message.content |
                if type == "string" then .[0:150]
                elif type == "array" then
                    ([.[] | select(.type == "text") | .text] | join(" "))[0:150]
                else ""
                end
            ' 2>/dev/null)

            # Count messages (user + assistant entries) - strip whitespace
            MSG_COUNT=$(grep -cE '"type":"(user|assistant)"' "$FILE" 2>/dev/null | tr -d '[:space:]')
            MSG_COUNT=${MSG_COUNT:-0}

            # Get last activity (use last line's timestamp or file mtime)
            LAST_LINE=$(tail -1 "$FILE")
            LAST_ACTIVITY=$(echo "$LAST_LINE" | jq -r '.timestamp // empty' 2>/dev/null)
            if [ -z "$LAST_ACTIVITY" ]; then
                LAST_ACTIVITY=$(date -Is -d "@$FILE_MTIME" 2>/dev/null || date -r "$FILE_MTIME" '+%Y-%m-%dT%H:%M:%S%z')
            fi

            # Build session entry
            if [ "$FIRST_ENTRY" -eq 0 ]; then
                echo "," >> "$INDEX_TMP"
            fi

            # Build JSON entry using jq for proper escaping, output as key:value
            ENTRY_JSON=$(jq -n -c \
                  --arg project "$PROJECT" \
                  --arg file "$FILE" \
                  --arg started "$STARTED" \
                  --arg last "$LAST_ACTIVITY" \
                  --argjson count "$MSG_COUNT" \
                  --arg summary "$FIRST_MSG" \
                  --argjson mtime "$FILE_MTIME" \
                '{project:$project,file:$file,started:$started,last_activity:$last,message_count:$count,summary:$summary,mtime:$mtime}')
            echo "\"$SESSION_ID\":$ENTRY_JSON" >> "$INDEX_TMP"
            FIRST_ENTRY=0
            ((UPDATED++)) || true

            # Progress indicator
            ((PROCESSED++)) || true
            if [ -n "$VERBOSE" ]; then
                echo "  [$PROCESSED/$TOTAL_FILES] $SESSION_ID"
            elif [ $((PROCESSED % 100)) -eq 0 ]; then
                echo "  Processed $PROCESSED/$TOTAL_FILES..."
            fi
        done < <(find "$CC_PROJECTS" -name "*.jsonl" -type f 2>/dev/null | grep -v '/agent-')

        # Close JSON structure
        echo '}' >> "$INDEX_TMP"
        echo '}' >> "$INDEX_TMP"

        # Validate and format JSON
        if jq '.' "$INDEX_TMP" > "$SHUTTLE_INDEX_FILE" 2>/dev/null; then
            SESSION_COUNT=$(jq '.sessions | length' "$SHUTTLE_INDEX_FILE")
            echo ""
            echo "Index complete: $SESSION_COUNT sessions"
            if [ -n "$UPDATE_MODE" ]; then
                echo "  Updated: $UPDATED, Skipped (unchanged): $SKIPPED"
            fi
            echo "Saved to: $SHUTTLE_INDEX_FILE"
        else
            echo "Error: Failed to create valid JSON index"
            cat "$INDEX_TMP"
            exit 1
        fi
        ;;

    help|--help|-h)
        cat << 'EOF'
shuttle - Manage Claude Code agent sessions

Commands:
  status          Show sessions, briefs, and shards (default)
  watch, w        Continuous status refresh (Ctrl-C to exit)
  ls              List active sessions
  board, b <n>    Board session by number or name
  kill, k <n>     Kill session by number or name
  peek, p <n> [lines]  Show last lines from session (default: 20)
  tail, t <n> [interval]  Live output stream from session (default: 1s refresh)
  context, ctx <n> [msgs]  Show conversation context (default: 10 messages)
  index, i        Build/update session index for fast search
  search <query>  Search CC session history (uses index)
  resume <id>     Resume a past CC session by UUID
  export, x <n|id>  Export session to markdown or JSON
  send <n> <msg>  Send message to session
  relay <n> <file>  Send file contents to session (use '-' for stdin)
  go, g <brief>   Launch new session on a brief
  split, s <brief>   Open brief in horizontal split pane
  vsplit, vs <brief> Open brief in vertical split pane
  unsplit         Close split pane
  ground          Kill all shuttle sessions
  config, cfg     Show current configuration

Index options:
  --update, -u    Incremental update (only changed files)
  --verbose, -v   Show progress for each file

Search options:
  --all, -a        Search all projects (default: current project)
  --list, -l       List sessions from index (no content search)
  --since, -s N    Only sessions from last N days
  --project, -p P  Filter by project path (substring match)
  --limit, -n N    Limit results (default: 20)

Options (for go, board, split, vsplit):
  -d, --dir PATH      Run in specified directory (go, split, vsplit)
  -p, --project NAME  Run in ~/projects/NAME (go, split, vsplit)
  --headless          Don't open GUI terminal (go, board)
  (default: current directory or SHUTTLE_DEFAULT_PROJECT, auto-headless if no $DISPLAY)

Configuration:
  Config file: ~/.config/shuttle/config or ~/.shuttlerc
  See 'shuttle config' for current settings and example config.

  Environment variables (override config file):
    SHUTTLE_PROJECT   Default project directory
    SHUTTLE_SITE      Default SKEIN site for briefs
    SHUTTLE_TERM      Terminal emulator command
    SHUTTLE_HEADLESS  Force headless mode (1 = always headless)
    SHUTTLE_TIMEOUT   Prompt detection timeout in seconds

Export options:
  --json, -j        Output as JSON instead of markdown
  --file, -f FILE   Write to file instead of stdout
  --last, -l N      Only include last N messages

Examples:
  shuttle                     # show status
  shuttle config              # show configuration
  shuttle index               # build full session index
  shuttle index --update      # incremental index update (~8s)
  shuttle search --list -a    # list all sessions from index
  shuttle search "auth" -a    # search content across all projects
  shuttle search -l -s 7      # list sessions from last 7 days
  shuttle go brief-20251210-ceor
  shuttle go -p skein brief-20251210-ceor  # launch in skein project
  shuttle go --headless brief-id  # create session without opening terminal
  shuttle split brief-20251210-ceor  # side-by-side pairing
  shuttle board 1             # board first session
  shuttle peek 1              # see what session 1 is doing
  shuttle peek 2 50           # last 50 lines from session 2
  shuttle tail 1              # live output from session 1
  shuttle tail 2 0.5          # faster refresh (0.5s interval)
  shuttle export 1            # export session 1 as markdown
  shuttle export 1 --json --file out.json  # export to JSON file
  shuttle send 1 "check the failing tests"  # nudge a session
  shuttle send 2 "skein torch"  # trigger retirement
  shuttle kill diverge        # kill session matching 'diverge'
EOF
        ;;

    *)
        echo "Unknown command: $CMD"
        echo "Run 'shuttle help' for usage"
        exit 1
        ;;
esac
